<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shared="clr-namespace:VinhKhanh.Shared;assembly=VinhKhanh.Shared"
             x:Class="VinhKhanh.Pages.HighlightsListPage"
             Title="Địa điểm thịnh hành">

        <CollectionView x:Name="CvAllHighlights" SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="shared:HighlightViewModel">
                <Frame Margin="10" CornerRadius="12" HasShadow="True" BackgroundColor="#FFFFFF">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnItemTapped" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="100, *" Padding="8">
                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" WidthRequest="96" HeightRequest="96" />
                        <StackLayout Grid.Column="1" Padding="8" Spacing="4">
                            <Label Text="{Binding Name}" FontAttributes="Bold" />
                            <Label Text="{Binding Address}" FontSize="12" TextColor="Gray" />
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding RatingDisplay}" FontSize="12" TextColor="#FBC02D" />
                                <Label Text="{Binding ReviewCountDisplay}" FontSize="12" TextColor="Gray" />
                                <Label Text="·" FontSize="12" />
                                <Label Text="{Binding Category}" FontSize="12" TextColor="Gray" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding PriceDisplay}" FontSize="12" TextColor="#00796B" FontAttributes="Bold" />
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding OpenStatus}" FontSize="12" TextColor="{Binding OpenStatusColorHex}" FontAttributes="Bold" />
                                <Label Text="·" FontSize="12" TextColor="#9AA0A6" />
                                <Label Text="{Binding OpeningHours}" FontSize="12" TextColor="Gray" />
                            </HorizontalStackLayout>
                        </StackLayout>
                    </Grid>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>