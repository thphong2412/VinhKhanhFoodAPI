<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             xmlns:shared="clr-namespace:VinhKhanh.Shared;assembly=VinhKhanh.Shared"
             x:Class="VinhKhanh.Pages.MapPage"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*" ColumnDefinitions="*">
        <!-- MAP ONLINE (Google/MAUI Maps) - FULL SCREEN -->
        <maps:Map x:Name="vinhKhanhMap" 
                  IsShowingUser="True" 
                  MapType="Street"
                  Grid.Row="0" Grid.Column="0"
                  ZIndex="0" />

        <!-- LOADING PLACEHOLDER (visible when map not ready) -->
        <StackLayout x:Name="MapLoadingPlaceholder"
                     IsVisible="False"
                     BackgroundColor="White"
                     Padding="20"
                     VerticalOptions="CenterAndExpand"
                     HorizontalOptions="CenterAndExpand"
                     Grid.Row="0" Grid.Column="0"
                     ZIndex="1">
            <Label Text="🗺️" FontSize="48" HorizontalTextAlignment="Center" />
            <Label x:Name="LblMapLoading" Text="Đang tải bản đồ..." FontSize="16" HorizontalTextAlignment="Center" Margin="0,10,0,0" />
            <ActivityIndicator IsRunning="True" Color="#FF8C00" Margin="0,10,0,0" />
        </StackLayout>

        <!-- MAPBOX OFFLINE (chỉ dùng khi user tải offline) -->
        <WebView x:Name="MapboxOfflineWebView"
                 Source="mapbox-offline.html"
                 IsVisible="False"
                 VerticalOptions="FillAndExpand"
                 HorizontalOptions="FillAndExpand"
                 Grid.Row="0" Grid.Column="0"
                 ZIndex="5" />

        <!-- TOP BAR - Above map -->
        <Grid VerticalOptions="Start" 
              Margin="15,50,15,0" 
              ColumnDefinitions="Auto, *, Auto"
              Grid.Row="0" Grid.Column="0"
              ZIndex="50">

            <Frame Grid.Column="0" Padding="0" CornerRadius="25"
                   WidthRequest="50" HeightRequest="50" BorderColor="Transparent">
                <Button Text="☰" FontSize="20"
                        BackgroundColor="White"
                        TextColor="Black"
                        Clicked="OnMenuClicked"/>
            </Frame>


            <Frame Grid.Column="1" Padding="12,0"
                   BackgroundColor="White"
                   CornerRadius="25"
                   HeightRequest="50"
                   Margin="10,0">
                <SearchBar x:Name="SearchPoiBar"
                           Placeholder="Tìm kiếm"
                           FontSize="14"
                           BackgroundColor="Transparent"
                           CancelButtonColor="#9AA0A6"
                           TextChanged="OnSearchPoiTextChanged"
                           SearchButtonPressed="OnSearchPoiSearchButtonPressed" />
            </Frame>

            <Frame Grid.Column="2" Padding="0"
                   CornerRadius="25"
                   WidthRequest="50"
                   HeightRequest="50"
                   BorderColor="Transparent">
                <Button Text="📷"
                        FontSize="20"
                        BackgroundColor="#FF5722"
                        TextColor="White"
                        Clicked="OnScanCameraClicked"/>
            </Frame>

        </Grid>

        <!-- GPS button (custom app button) -->
        <Frame x:Name="GpsButtonFrame" Grid.Row="0" Grid.Column="0"
               ZIndex="60"
               VerticalOptions="End"
               HorizontalOptions="End"
               Margin="0,0,18,190"
               Padding="0"
               WidthRequest="52"
               HeightRequest="52"
               CornerRadius="26"
               BackgroundColor="White"
               HasShadow="True"
               BorderColor="#E0E0E0">
            <Button Text="🎯"
                    FontSize="20"
                    BackgroundColor="Transparent"
                    TextColor="#1A73E8"
                    Clicked="OnMyLocationClicked" />
        </Frame>

        <VerticalStackLayout x:Name="MapZoomControls"
                             Grid.Row="0" Grid.Column="0"
                             ZIndex="60"
                             VerticalOptions="End"
                             HorizontalOptions="End"
                             Margin="0,0,18,250"
                             Spacing="10">
            <Frame Padding="0"
                   WidthRequest="52"
                   HeightRequest="52"
                   CornerRadius="26"
                   BackgroundColor="White"
                   HasShadow="True"
                   BorderColor="#E0E0E0">
                <Button Text="+"
                        FontSize="26"
                        BackgroundColor="Transparent"
                        TextColor="#1A73E8"
                        Clicked="OnZoomInClicked" />
            </Frame>

            <Frame Padding="0"
                   WidthRequest="52"
                   HeightRequest="52"
                   CornerRadius="26"
                   BackgroundColor="White"
                   HasShadow="True"
                   BorderColor="#E0E0E0">
                <Button Text="−"
                        FontSize="26"
                        BackgroundColor="Transparent"
                        TextColor="#1A73E8"
                        Clicked="OnZoomOutClicked" />
            </Frame>
        </VerticalStackLayout>

        <!-- LANGUAGE PANEL - Modal overlay, HIGH z-index -->
        <Grid x:Name="LanguagePanel"
              IsVisible="False"
              BackgroundColor="#80000000"
              Grid.Row="0" Grid.Column="0"
              ZIndex="200">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseMenuClicked"/>
            </Grid.GestureRecognizers>

                <Frame HorizontalOptions="Center" VerticalOptions="Center"
                   WidthRequest="340"
                   BackgroundColor="White"
                   CornerRadius="20"
                   Padding="18,22,18,22"
                   HasShadow="True">

                <ScrollView HeightRequest="560" VerticalScrollBarVisibility="Always">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="LblLangTitle" Text="Chọn ngôn ngữ" FontSize="20" FontAttributes="Bold" TextColor="Black" VerticalOptions="Center" />
                        <Button x:Name="BtnCloseLangPanelX"
                                Grid.Column="1"
                                Text="✕"
                                WidthRequest="36"
                                HeightRequest="36"
                                CornerRadius="18"
                                BackgroundColor="#F5F5F5"
                                TextColor="#333333"
                                Clicked="OnCloseMenuClicked" />
                    </Grid>

                    <ScrollView HeightRequest="360">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10">
                            <Button x:Name="BtnLangVI" Grid.Row="0" Grid.Column="0" Text="🇻🇳 Tiếng Việt" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectVietnameseClicked" />
                            <Button x:Name="BtnLangEN" Grid.Row="0" Grid.Column="1" Text="🇺🇸 English" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectEnglishClicked" />

                            <Button x:Name="BtnLangJA" Grid.Row="1" Grid.Column="0" Text="🇯🇵 日本語" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectJapaneseClicked" />
                            <Button x:Name="BtnLangKO" Grid.Row="1" Grid.Column="1" Text="🇰🇷 한국어" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectKoreanClicked" />

                            <Button x:Name="BtnLangRU" Grid.Row="2" Grid.Column="0" Text="🇷🇺 Русский" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectRussianClicked" />
                            <Button x:Name="BtnLangFR" Grid.Row="2" Grid.Column="1" Text="🇫🇷 Français" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectFrenchClicked" />

                            <Button x:Name="BtnLangTH" Grid.Row="3" Grid.Column="0" Text="🇹🇭 ไทย" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectThaiClicked" />
                            <Button x:Name="BtnLangZH" Grid.Row="3" Grid.Column="1" Text="🇨🇳 中文" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectChineseClicked" />

                            <Button x:Name="BtnLangES" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="🇪🇸 Español" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectSpanishClicked" />
                        </Grid>
                    </ScrollView>

                    <Frame Padding="10" CornerRadius="10" BackgroundColor="#F8F9FB" HasShadow="False" BorderColor="#E1E5EE">
                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="LblCustomLanguageTitle" Text="Ngôn ngữ khác (custom)" FontSize="13" FontAttributes="Bold" TextColor="#1F2937" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry x:Name="TxtCustomLanguageCode"
                                       Placeholder="Ví dụ: de, it, ar, hi..."
                                       MaxLength="12"
                                       TextColor="#111827"
                                       BackgroundColor="White" />
                                <Button Grid.Column="1"
                                        x:Name="BtnApplyCustomLanguage"
                                        Text="Áp dụng"
                                        HeightRequest="40"
                                        BackgroundColor="#111827"
                                        TextColor="White"
                                        CornerRadius="10"
                                        Clicked="OnApplyCustomLanguageClicked" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Padding="12" CornerRadius="12" BackgroundColor="#F5F7FF" HasShadow="False" BorderColor="#D7DEFF">
                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="LblOfflineMapTitle" Text="🗺️ Bản đồ offline" FontSize="14" FontAttributes="Bold" TextColor="#1A237E" />
                            <Label x:Name="LblOfflineMapStatus" Text="Trạng thái: Chưa tải bản đồ offline" FontSize="12" TextColor="#455A64" />
                            <Label x:Name="LblOfflineMapProgress" Text="Tiến độ: 0%" FontSize="12" TextColor="#1A237E" />
                            <ProgressBar x:Name="PbOfflineMapProgress"
                                         Progress="0"
                                         ProgressColor="#1A73E8"
                                         BackgroundColor="#D7DEFF"
                                         HeightRequest="8" />
                            <Grid ColumnDefinitions="*" RowDefinitions="Auto" RowSpacing="8">
                                <Button x:Name="BtnEnableOfflineMap" Grid.Row="0" Text="Tải map offline" BackgroundColor="#1A73E8" TextColor="White" CornerRadius="10" HeightRequest="40" Clicked="OnEnableOfflineMapClicked" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <Button x:Name="BtnForceSyncNow"
                            Text="Force Sync now"
                            HeightRequest="44"
                            BackgroundColor="#0F766E"
                            TextColor="White"
                            CornerRadius="10"
                            Clicked="OnForceSyncNowClicked" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button x:Name="BtnCloseMenu" Grid.Column="0" Text="Hủy" HeightRequest="44" BackgroundColor="#EEEEEE" TextColor="#333" CornerRadius="10" Clicked="OnCloseMenuClicked" />
                        <Button x:Name="BtnConfirmMenu" Grid.Column="1" Text="OK" HeightRequest="44" BackgroundColor="#1A73E8" TextColor="White" CornerRadius="10" Clicked="OnConfirmLanguageClicked" />
                    </Grid>
                </VerticalStackLayout>
                </ScrollView>
            </Frame>
        </Grid>

        <!-- POI DETAIL -->
        <!-- HIGHLIGHTS PANEL (shown when no POI selected) - Modal overlay -->
        <Frame x:Name="HighlightsPanel"
       VerticalOptions="End"
       IsVisible="False"
       Margin="0,0,0,0"
       Padding="14,10,14,12"
       BackgroundColor="#FFFFFF"
       CornerRadius="26"
          HeightRequest="112"
       Grid.Row="0" Grid.Column="0"
        ZIndex="120">

            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnHighlightsPanelTapped" />
            </Frame.GestureRecognizers>

            <ScrollView VerticalScrollBarVisibility="Always">
            <VerticalStackLayout Spacing="10">
                <BoxView HeightRequest="5" WidthRequest="54" CornerRadius="3" Color="#D6D6D6" HorizontalOptions="Center" Margin="0,2,0,2">
                    <BoxView.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnHighlightsPanUpdated" />
                        <TapGestureRecognizer Tapped="OnHighlightsPanelTapped" />
                    </BoxView.GestureRecognizers>
                </BoxView>
                <!-- header: title + saved shortcut + weather -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label x:Name="LblHighlightsTitle" Text="Nổi bật trong khu vực" FontSize="24" FontAttributes="Bold" TextColor="#1B1B1F" Grid.Column="0" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHighlightsTitleTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                        <Button x:Name="BtnSavedShortcut" Text="Đã lưu" BackgroundColor="#E8F5E9" TextColor="#2E7D32" CornerRadius="16" Padding="8,3" FontSize="12" HeightRequest="32" Clicked="OnViewSavedClicked" />
                        <Frame BackgroundColor="#EEF4FF" CornerRadius="14" Padding="10,4" HasShadow="False" BorderColor="#D6E4FF">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="☀️" FontSize="13" VerticalTextAlignment="Center" />
                                <Label Text="TP.HCM" FontSize="12" FontAttributes="Bold" TextColor="#1E3A8A" VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Frame>
                    </HorizontalStackLayout>
                    <VerticalStackLayout x:Name="HighlightScrollControls" Grid.Column="2" Spacing="4" VerticalOptions="Center" IsVisible="False">
                        <Button x:Name="BtnScrollHighlightsUp" Text="▲" WidthRequest="30" HeightRequest="18" CornerRadius="9" Padding="0" BackgroundColor="#EEF2FF" TextColor="#3949AB" FontSize="10" Clicked="OnScrollHighlightsUpClicked" />
                        <Button x:Name="BtnScrollHighlightsDown" Text="▼" WidthRequest="30" HeightRequest="18" CornerRadius="9" Padding="0" BackgroundColor="#EEF2FF" TextColor="#3949AB" FontSize="10" Clicked="OnScrollHighlightsDownClicked" />
                    </VerticalStackLayout>
                    <Button x:Name="BtnToggleHighlights" Grid.Column="3" Text="+" WidthRequest="36" HeightRequest="36" CornerRadius="18" Padding="0" BackgroundColor="#F2F2F2" TextColor="#555555" FontSize="24" Clicked="OnToggleHighlightsClicked" />
                </Grid>

                <CollectionView x:Name="CvHighlights" ItemsLayout="HorizontalList" HeightRequest="120" HorizontalScrollBarVisibility="Never" SelectionMode="Single" SelectionChanged="OnHighlightSelected" ZIndex="10" ItemSizingStrategy="MeasureFirstItem">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="shared:HighlightViewModel">
                            <Frame WidthRequest="320" HeightRequest="240" CornerRadius="20" Margin="6" HasShadow="True" BackgroundColor="#FFF9F0" BorderColor="#F2E7D3">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="120" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="96">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnHighlightItemTapped" NumberOfTapsRequired="1" />
                                            </Image.GestureRecognizers>
                                        </Image>
                                        <Frame HorizontalOptions="End" VerticalOptions="Start" Margin="8" Padding="10,4" CornerRadius="16" BackgroundColor="#EDEDED" HasShadow="False">
                                            <Label Text="{Binding BadgeText}" FontSize="12" FontAttributes="Bold" TextColor="#1B1B1F" />
                                        </Frame>
                                    </Grid>

                                    <StackLayout Grid.Row="1" Padding="10,8" Spacing="2">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" LineBreakMode="WordWrap" MaxLines="2">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnHighlightItemTapped" NumberOfTapsRequired="1" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <Label Text="{Binding PopularHint}" FontSize="11" TextColor="#D32F2F" FontAttributes="Bold" IsVisible="{Binding IsHot}" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding RatingDisplay}" FontSize="13" TextColor="#F9A825" />
                                            <Label Text="{Binding ReviewCountDisplay}" FontSize="12" TextColor="#5F6368" />
                                            <Label Text="·" FontSize="12" TextColor="#9AA0A6" />
                                            <Label Text="{Binding Category}" FontSize="12" TextColor="#5F6368" LineBreakMode="TailTruncation" MaxLines="1" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding PriceDisplay}" FontSize="12" TextColor="#00796B" FontAttributes="Bold" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding OpenStatus}" FontSize="12" TextColor="{Binding OpenStatusColorHex}" FontAttributes="Bold" />
                                            <Label Text="·" FontSize="12" TextColor="#9AA0A6" />
                                            <Label Text="{Binding OpeningHours}" FontSize="12" TextColor="#5F6368" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Address}" FontSize="12" TextColor="#5F6368" LineBreakMode="WordWrap" MaxLines="2" />
                                    </StackLayout>

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnHighlightTapped" NumberOfTapsRequired="1" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <ActivityIndicator x:Name="HighlightsLoadingIndicator"
                                   IsVisible="False"
                                   IsRunning="False"
                                   HeightRequest="24"
                                   Color="#3949AB"
                                   HorizontalOptions="Center" />

                <Button x:Name="BtnViewAllHighlights" Text="Xem thêm" BackgroundColor="#ECEFF1" TextColor="#1B1B1F" CornerRadius="18" HeightRequest="46" Padding="16,10" LineBreakMode="NoWrap" HorizontalOptions="Fill" Clicked="OnViewAllHighlightsClicked"/>
            </VerticalStackLayout>
            </ScrollView>
        </Frame>

        <Frame x:Name="PoiDetailPanel"
       VerticalOptions="End"
       IsVisible="False"
       Margin="10,0,10,30"
       Padding="0"
       BackgroundColor="White"
       CornerRadius="20"
        HeightRequest="560"
        ZIndex="160">

            <Grid RowDefinitions="232,*">

                <!-- ẢNH: Carousel hiển thị tối đa 5 ảnh, hỗ trợ vuốt/ngón tay kéo (kích thước lớn hơn) -->
                <Frame Grid.Row="0" Padding="0" HasShadow="False" CornerRadius="12" Margin="12,12,12,0" HeightRequest="208" HorizontalOptions="FillAndExpand">
                    <Grid>
                        <CarouselView x:Name="ImgCarousel" ItemsLayout="HorizontalList" PeekAreaInsets="0" IndicatorView="ImgIndicator">
                            <CarouselView.ItemTemplate>
                                <DataTemplate>
                                    <Image Aspect="AspectFill" Source="{Binding}" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand"/>
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>
                        <!-- Indicators -->
                        <IndicatorView x:Name="ImgIndicator" HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,6" />

                        <!-- Left / right arrows overlay -->
                        <Button Text="‹" FontSize="24" BackgroundColor="#55FFFFFF" WidthRequest="44" HeightRequest="44" CornerRadius="22" HorizontalOptions="Start" VerticalOptions="Center" Margin="8,0" Clicked="OnImgPrevClicked" />
                        <Button Text="›" FontSize="24" BackgroundColor="#55FFFFFF" WidthRequest="44" HeightRequest="44" CornerRadius="22" HorizontalOptions="End" VerticalOptions="Center" Margin="8,0" Clicked="OnImgNextClicked" />
                    </Grid>
                </Frame>

                <!-- Drag grip: placed at bottom of image so user can drag panel up/down -->
                <Frame Grid.Row="0" HorizontalOptions="Center" VerticalOptions="End" HeightRequest="28" WidthRequest="80" CornerRadius="14" BackgroundColor="#88FFFFFF" HasShadow="False" Margin="0,0,0,6">
                    <Frame.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnPoiDetailPanUpdated" />
                    </Frame.GestureRecognizers>
                    <BoxView HeightRequest="4" WidthRequest="36" CornerRadius="2" BackgroundColor="#888" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>

                <!-- NÚT ĐÓNG (nằm trên ảnh) -->
                <Button Text="✕"
                x:Name="BtnCloseDetail"
                Grid.Row="0"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="10"
                BackgroundColor="White"
                TextColor="Black"
                FontAttributes="Bold"
                WidthRequest="44"
                HeightRequest="44"
                CornerRadius="22"
                Clicked="OnCloseDetailClicked"/>

                <!-- NỘI DUNG (scrollable) -->
                <ScrollView Grid.Row="1" VerticalOptions="FillAndExpand" Margin="0,10,0,0">
                    <VerticalStackLayout
                             Padding="20,15"
                             Spacing="6">

                    <Label x:Name="LblPoiName"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="Black"/>

                    <Label x:Name="LblSubtitle" FontSize="15" TextColor="#616161" LineBreakMode="WordWrap" />

                    <Label x:Name="LblPrice" Text="" FontSize="14" TextColor="#00796B" FontAttributes="Bold" />

                    <!-- Rating row -->
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label x:Name="LblRating" Text="" FontSize="16" TextColor="#FBC02D" />
                        <Label x:Name="LblReviewCount" Text="" FontSize="14" TextColor="Gray" />
                    </HorizontalStackLayout>

                    <!-- quick chips -->
                    <HorizontalStackLayout Spacing="8">
                        <Frame Padding="8,3" CornerRadius="12" BackgroundColor="#E8F5E9" HasShadow="False">
                            <Label x:Name="LblPoiCategory" Text="" FontSize="12" TextColor="#2E7D32" FontAttributes="Bold" />
                        </Frame>
                        <Frame Padding="8,3" CornerRadius="12" BackgroundColor="#E3F2FD" HasShadow="False">
                            <Label x:Name="LblRadiusChip" Text="" FontSize="12" TextColor="#1565C0" FontAttributes="Bold" />
                        </Frame>
                        <Frame Padding="8,3" CornerRadius="12" BackgroundColor="#FFF3E0" HasShadow="False">
                            <Label x:Name="LblPriorityChip" Text="" FontSize="12" TextColor="#EF6C00" FontAttributes="Bold" />
                        </Frame>
                    </HorizontalStackLayout>

                    <!-- Tabs: Tổng quan / Giới thiệu / Đánh giá -->
                    <Grid ColumnDefinitions="*, *, *" Margin="0,6,0,0" ColumnSpacing="4">
                        <Button x:Name="TabOverview" Text="Tổng quan" BackgroundColor="Transparent" TextColor="#00796B" FontAttributes="Bold" FontSize="13" Padding="6,8" LineBreakMode="NoWrap" HorizontalOptions="Fill" Clicked="OnTabOverviewClicked" />
                        <Button x:Name="TabIntro" Grid.Column="1" Text="Giới thiệu" BackgroundColor="Transparent" TextColor="Gray" FontSize="13" Padding="6,8" LineBreakMode="NoWrap" HorizontalOptions="Fill" Clicked="OnTabIntroClicked" />
                        <Button x:Name="TabReview" Grid.Column="2" Text="Đánh giá" BackgroundColor="Transparent" TextColor="Gray" FontSize="13" Padding="6,8" LineBreakMode="NoWrap" HorizontalOptions="Fill" Clicked="OnTabReviewClicked" />
                    </Grid>

                    <!-- Overview panel: the big 4 action buttons -->
                    <VerticalStackLayout x:Name="OverviewPanel" Spacing="8" Padding="0,8,0,0">
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                            <!-- Directions: pill button with icon + label -->
                            <Frame x:Name="FrameDirections" Grid.Row="0" Grid.Column="0" CornerRadius="20" Padding="14,12" BackgroundColor="#00796B" HasShadow="False" HorizontalOptions="Fill" VerticalOptions="Center" MinimumHeightRequest="52">
                                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" InputTransparent="True">
                                    <Label x:Name="LblActDirections" Text="Dẫn đường" TextColor="White" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer CommandParameter="directions" Tapped="OnGetDirectionsClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                            <!-- Audio: play POI audio directly (if available) -->
                            <Frame x:Name="FrameAudio" Grid.Row="0" Grid.Column="1" CornerRadius="20" Padding="14,12" BackgroundColor="#FFF8E1" HasShadow="False" HorizontalOptions="Fill" VerticalOptions="Center" MinimumHeightRequest="52">
                                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" InputTransparent="True">
                                    <Label x:Name="LblActAudio" Text="Nghe ngay" TextColor="#EF6C00" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPlayPoiAudioClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                            <!-- Audio: open choices Audio / TTS -->
                            <Frame x:Name="FrameNarration" Grid.Row="1" Grid.Column="0" CornerRadius="20" Padding="14,12" BackgroundColor="#E0F7FA" HasShadow="False" HorizontalOptions="Fill" VerticalOptions="Center" MinimumHeightRequest="52">
                                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" InputTransparent="True">
                                    <Label x:Name="LblActNarration" Text="Audio" TextColor="#00796B" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStartNarrationClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                            <!-- Share -->
                            <Frame x:Name="FrameShare" Grid.Row="1" Grid.Column="1" CornerRadius="20" Padding="14,12" BackgroundColor="#E8F5E9" HasShadow="False" HorizontalOptions="Fill" VerticalOptions="Center" MinimumHeightRequest="52">
                                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" InputTransparent="True">
                                    <Label x:Name="LblActShare" Text="Chia sẻ" TextColor="#2E7D32" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnShareClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                            <!-- Save -->
                            <Frame x:Name="FrameSave" Grid.Row="2" Grid.Column="0" CornerRadius="20" Padding="14,12" BackgroundColor="#FFF3E0" HasShadow="False" HorizontalOptions="Fill" VerticalOptions="Center" MinimumHeightRequest="52">
                                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" InputTransparent="True">
                                    <Label x:Name="LblActSave" Text="Lưu" TextColor="#EF6C00" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSaveClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                            <!-- QR -->
                            <Frame Grid.Row="2" Grid.Column="1" CornerRadius="20" Padding="14,12" BackgroundColor="#E8F5E9" HasShadow="False" HorizontalOptions="Fill" VerticalOptions="Center" MinimumHeightRequest="52">
                                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" InputTransparent="True">
                                    <Label x:Name="LblActQr" Text="Mã QR" TextColor="#2E7D32" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnShowQrClicked_Map" />
                                </Frame.GestureRecognizers>
                            </Frame>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Introduction panel (description) -->
                    <VerticalStackLayout x:Name="IntroPanel" IsVisible="False" Spacing="6">
                        <Label x:Name="LblDescription" FontSize="14" TextColor="Gray" LineBreakMode="WordWrap" />
                        <Button x:Name="BtnToggleDescription" Text="Xem thêm" BackgroundColor="Transparent" TextColor="#1A73E8" Clicked="OnToggleDescriptionClicked" HorizontalOptions="Start" />
                    </VerticalStackLayout>

                    <!-- Review panel -->
                    <VerticalStackLayout x:Name="ReviewPanel" IsVisible="False" Spacing="8" Padding="0,8,0,0">
                        <Frame Padding="12" CornerRadius="12" BackgroundColor="#FFFDE7" HasShadow="False" BorderColor="#FFF176">
                            <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                                <Label Text="⭐" FontSize="18" />
                                <Label x:Name="LblReviewsSummary" FontSize="14" TextColor="#5F6368" />
                            </HorizontalStackLayout>
                        </Frame>
                        <Label x:Name="LblReviewHint" Text="" FontSize="12" TextColor="#9AA0A6" />
                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,8" />

                    <!-- Additional info rows -->
                    <VerticalStackLayout Spacing="8">
                        <Frame Padding="10,8" CornerRadius="12" BackgroundColor="#FAFAFA" HasShadow="False">
                            <VerticalStackLayout Spacing="6">
                                <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                                    <Label x:Name="LblAddressTitle" Text="Địa chỉ" FontSize="14" FontAttributes="Bold" TextColor="#374151" />
                                    <Label Text=":" FontSize="14" TextColor="#374151" />
                                </HorizontalStackLayout>
                                <Label x:Name="LblAddress" FontSize="14" TextColor="Gray" LineBreakMode="WordWrap" MaxLines="6" />
                            </VerticalStackLayout>
                        </Frame>

                        <Frame Padding="10,8" CornerRadius="12" BackgroundColor="#FAFAFA" HasShadow="False">
                            <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                                <Label x:Name="LblDistanceTitle" Text="Khoảng cách" FontSize="14" FontAttributes="Bold" TextColor="#374151" />
                                <Label Text=":" FontSize="14" TextColor="#374151" />
                                <Label x:Name="LblDistance" FontSize="14" TextColor="#455A64" />
                                <Label x:Name="LblCoordinates" FontSize="12" TextColor="#78909C" HorizontalOptions="EndAndExpand" />
                            </HorizontalStackLayout>
                        </Frame>

                        <Frame Padding="10,8" CornerRadius="12" BackgroundColor="#FAFAFA" HasShadow="False">
                            <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                            <Label x:Name="LblOpeningHoursTitle" Text="Giờ mở cửa" FontSize="14" FontAttributes="Bold" TextColor="#374151" />
                            <Label Text=":" FontSize="14" TextColor="#374151" />
                            <Label x:Name="LblOpeningHours" FontSize="14" TextColor="Gray" />
                            <Label x:Name="LblOpenStatus" FontSize="14" TextColor="#388E3C" HorizontalOptions="End" />
                            </HorizontalStackLayout>
                        </Frame>

                        <Frame Padding="10,8" CornerRadius="12" BackgroundColor="#FAFAFA" HasShadow="False">
                            <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                            <Label x:Name="LblWebsiteTitle" Text="Website" FontSize="14" FontAttributes="Bold" TextColor="#374151" />
                            <Label Text=":" FontSize="14" TextColor="#374151" />
                            <Label x:Name="LblWebsite" FontSize="14" TextColor="#1A73E8" TextDecorations="Underline" />
                            <HorizontalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnWebsiteTapped" />
                            </HorizontalStackLayout.GestureRecognizers>
                            </HorizontalStackLayout>
                        </Frame>

                        <Frame Padding="10,8" CornerRadius="12" BackgroundColor="#FAFAFA" HasShadow="False">
                            <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                            <Label x:Name="LblPhoneTitle" Text="Điện thoại" FontSize="14" FontAttributes="Bold" TextColor="#374151" />
                            <Label Text=":" FontSize="14" TextColor="#374151" />
                            <Label x:Name="LblPhone" FontSize="14" TextColor="Gray" />
                            <HorizontalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPhoneTapped" />
                            </HorizontalStackLayout.GestureRecognizers>
                            </HorizontalStackLayout>
                        </Frame>

                    </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Frame>

        <!-- TRACKING CONTROL PANEL -->
        <Frame VerticalOptions="End" HorizontalOptions="Start" Margin="15,0,0,200" Padding="8" CornerRadius="12" BackgroundColor="#CCFFFFFF" IsVisible="False">
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout Spacing="8">
                    <Button x:Name="BtnStartTracking" Text="Bắt đầu" Clicked="OnStartTrackingClicked" BackgroundColor="#1A73E8" TextColor="White" />
                    <Button x:Name="BtnStopTracking" Text="Dừng" Clicked="OnStopTrackingClicked" BackgroundColor="#BDBDBD" TextColor="Black" IsEnabled="False" />
                </HorizontalStackLayout>
                <Label x:Name="LblTrackingStatus" Text="Trạng thái: đã dừng" FontSize="12" TextColor="Black"/>
                <CollectionView x:Name="CvLog" HeightRequest="120">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding .}" FontSize="12" TextColor="Black" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Frame>

        <!-- SHOW SAVED POIS BUTTON (CENTER BOTTOM) -->
        <Button x:Name="BtnShowSaved"
                IsVisible="False"
                Text="Hiện những địa điểm đã lưu"
                FontSize="14"
                BackgroundColor="#673AB7"
                TextColor="White"
                CornerRadius="20"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,140"
                Padding="14,8"
                Clicked="OnShowSavedClicked"/>

    </Grid>
</ContentPage>