<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="VinhKhanh.Pages.MapPage"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- MAP ONLINE (Google/MAUI Maps) -->
        <maps:Map x:Name="vinhKhanhMap" IsShowingUser="True" MapType="Street" />

        <!-- MAPBOX OFFLINE (ẩn khi online) -->
        <WebView x:Name="MapboxOfflineWebView"
                 Source="mapbox-offline.html"
                 IsVisible="False"
                 VerticalOptions="FillAndExpand"
                 HorizontalOptions="FillAndExpand" />

        <!-- TOP BAR -->
        <Grid VerticalOptions="Start" Margin="15,50,15,0" ColumnDefinitions="Auto, *, Auto">

            <Frame Grid.Column="0" Padding="0" CornerRadius="25"
                   WidthRequest="50" HeightRequest="50" BorderColor="Transparent">
                <Button Text="☰" FontSize="20"
                        BackgroundColor="White"
                        TextColor="Black"
                        Clicked="OnMenuClicked"/>
            </Frame>


            <Frame Grid.Column="1" Padding="15,0"
                   BackgroundColor="White"
                   CornerRadius="25"
                   HeightRequest="50"
                   Margin="10,0">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Text="🔍" VerticalOptions="Center" Margin="0,0,10,0"/>
                    <Label x:Name="LblSearchPlaceholder" Grid.Column="1"
                           Text="Tìm kiếm..."
                           VerticalOptions="Center"
                           TextColor="Gray"/>
                </Grid>
            </Frame>

            <Frame Grid.Column="2" Padding="0"
                   CornerRadius="25"
                   WidthRequest="50"
                   HeightRequest="50"
                   BorderColor="Transparent">
                <Button Text="📷"
                        FontSize="20"
                        BackgroundColor="#FF5722"
                        TextColor="White"
                        Clicked="OnScanCameraClicked"/>
            </Frame>

        </Grid>

        <!-- GPS BUTTON -->
        <Frame VerticalOptions="End"
               HorizontalOptions="End"
               Margin="0,0,15,110"
               Padding="0"
               CornerRadius="25"
               WidthRequest="50"
               HeightRequest="50"
               BorderColor="Transparent">
            <Button Text="🎯"
                    FontSize="20"
                    BackgroundColor="White"
                    TextColor="#1A73E8"
                    Clicked="OnMyLocationClicked"/>
        </Frame>

        <!-- LANGUAGE PANEL -->
        <Grid x:Name="LanguagePanel"
              IsVisible="False"
              BackgroundColor="#80000000"
              ZIndex="100">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseMenuClicked"/>
            </Grid.GestureRecognizers>

                <Frame HorizontalOptions="Center" VerticalOptions="Center"
                   WidthRequest="320"
                   BackgroundColor="White"
                   CornerRadius="20"
                   Padding="18,22,18,22"
                   HasShadow="True">

                <VerticalStackLayout Spacing="12">
                    <Label x:Name="LblLangTitle" Text="Chọn ngôn ngữ" FontSize="20" FontAttributes="Bold" TextColor="Black" />

                    <VerticalStackLayout Spacing="12">
                        <Button x:Name="BtnLangVI" Text="🇻🇳 Tiếng Việt" BackgroundColor="#E3F2FD" TextColor="#1A73E8" CornerRadius="12" HeightRequest="44" Clicked="OnSelectVietnameseClicked" />
                        <Button x:Name="BtnLangEN" Text="🇺🇸 Tiếng Anh" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectEnglishClicked" />
                        <Button x:Name="BtnLangJA" Text="🇯🇵 日本語" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectJapaneseClicked" />
                        <Button x:Name="BtnLangKO" Text="🇰🇷 한국어" BackgroundColor="Transparent" TextColor="Gray" CornerRadius="12" HeightRequest="44" Clicked="OnSelectKoreanClicked" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                        <Button x:Name="BtnCloseMenu" Text="Hủy" BackgroundColor="#EEEEEE" TextColor="#333" Clicked="OnCloseMenuClicked" />
                        <Button x:Name="BtnConfirmMenu" Text="OK" BackgroundColor="#1A73E8" TextColor="White" Clicked="OnConfirmLanguageClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- POI DETAIL -->
        <!-- HIGHLIGHTS PANEL (shown when no POI selected) -->
        <Frame x:Name="HighlightsPanel"
       VerticalOptions="End"
       IsVisible="False"
       Margin="10,0,10,30"
       Padding="12"
       BackgroundColor="White"
       CornerRadius="20"
       HeightRequest="240">

            <Frame.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnHighlightsPanUpdated" />
            </Frame.GestureRecognizers>

            <VerticalStackLayout Spacing="8">
                <!-- header: title + saved shortcut + weather -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label x:Name="LblHighlightsTitle" Text="Nổi bật trong khu vực" FontSize="20" FontAttributes="Bold" Grid.Column="0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHighlightsTitleTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <HorizontalStackLayout Grid.Column="1" Spacing="8">
                        <Button x:Name="BtnSavedShortcut" Text="Đã lưu" BackgroundColor="#E3F2FD" TextColor="#1A73E8" CornerRadius="18" Padding="8,4" Clicked="OnViewSavedClicked" />
                        <Frame BackgroundColor="#FFF3E0" CornerRadius="12" Padding="6" HasShadow="False">
                            <Label Text="🌤 34°" FontSize="14" />
                        </Frame>
                    </HorizontalStackLayout>
                </Grid>

                <CollectionView x:Name="CvHighlights" ItemsLayout="HorizontalList" HeightRequest="160" HorizontalScrollBarVisibility="Never" SelectionMode="Single" SelectionChanged="OnHighlightSelected" ZIndex="10">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame WidthRequest="300" HeightRequest="150" CornerRadius="14" Margin="8" HasShadow="True" BackgroundColor="#FFFFFF">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" WidthRequest="120" HeightRequest="150" Grid.Column="0" />
                                    <StackLayout Grid.Column="1" Padding="10,8" Spacing="4">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding RatingDisplay}" FontSize="13" TextColor="#FBC02D" />
                                            <Label Text="({Binding ReviewCount})" FontSize="12" TextColor="Gray" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Category}" FontSize="12" TextColor="Gray" />
                                        <HorizontalStackLayout Spacing="8" VerticalOptions="EndAndExpand">
                                            <Label Text="{Binding OpeningHours}" FontSize="12" TextColor="Gray" />
                                            <Label Text="·" FontSize="12" TextColor="Gray" />
                                            <Label Text="{Binding OpenStatus}" FontSize="12" TextColor="Gray">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding OpenStatusColorHex}" Value="">
                                                        <!-- no-op when empty -->
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </StackLayout>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnHighlightTapped" NumberOfTapsRequired="1" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button x:Name="BtnViewAllHighlights" Text="Xem tất cả các địa điểm thịnh hành" BackgroundColor="#ECEFF1" TextColor="#37474F" CornerRadius="20" Clicked="OnViewAllHighlightsClicked"/>
            </VerticalStackLayout>
        </Frame>

        <Frame x:Name="PoiDetailPanel"
       VerticalOptions="End"
       IsVisible="False"
       Margin="10,0,10,30"
       Padding="0"
       BackgroundColor="White"
       CornerRadius="20"
       HeightRequest="520">

            <Grid RowDefinitions="150, *">

                <!-- ẢNH: Carousel hiển thị tối đa 5 ảnh, hỗ trợ vuốt/ngón tay kéo (kích thước lớn hơn) -->
                <Frame Padding="0" HasShadow="False" CornerRadius="12" Margin="12" HeightRequest="220" HorizontalOptions="FillAndExpand">
                    <Grid>
                        <CarouselView x:Name="ImgCarousel" ItemsLayout="HorizontalList" PeekAreaInsets="0" IndicatorView="ImgIndicator">
                            <CarouselView.ItemTemplate>
                                <DataTemplate>
                                    <Image Aspect="AspectFill" Source="{Binding}" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand"/>
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>
                        <!-- Indicators -->
                        <IndicatorView x:Name="ImgIndicator" HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,6" />

                        <!-- Left / right arrows overlay -->
                        <Button Text="‹" FontSize="24" BackgroundColor="#55FFFFFF" WidthRequest="44" HeightRequest="44" CornerRadius="22" HorizontalOptions="Start" VerticalOptions="Center" Margin="8,0" Clicked="OnImgPrevClicked" />
                        <Button Text="›" FontSize="24" BackgroundColor="#55FFFFFF" WidthRequest="44" HeightRequest="44" CornerRadius="22" HorizontalOptions="End" VerticalOptions="Center" Margin="8,0" Clicked="OnImgNextClicked" />
                    </Grid>
                </Frame>

                <!-- Drag grip: placed at bottom of image so user can drag panel up/down -->
                <Frame Grid.Row="0" HorizontalOptions="Center" VerticalOptions="End" HeightRequest="28" WidthRequest="80" CornerRadius="14" BackgroundColor="#88FFFFFF" HasShadow="False" Margin="0,0,0,6">
                    <Frame.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnPoiDetailPanUpdated" />
                    </Frame.GestureRecognizers>
                    <BoxView HeightRequest="4" WidthRequest="36" CornerRadius="2" BackgroundColor="#888" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>

                <!-- NÚT ĐÓNG (nằm trên ảnh) -->
                <Button Text="✕"
                x:Name="BtnCloseDetail"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="10"
                BackgroundColor="White"
                TextColor="Black"
                FontAttributes="Bold"
                WidthRequest="44"
                HeightRequest="44"
                CornerRadius="22"
                Clicked="OnCloseDetailClicked"/>

                <!-- NỘI DUNG (scrollable) -->
                <ScrollView Grid.Row="1" VerticalOptions="FillAndExpand">
                    <VerticalStackLayout
                             Padding="20,15"
                             Spacing="6">

                    <Label x:Name="LblPoiName"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="Black"/>

                    <!-- Rating row: stars + reviews + category -->
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label x:Name="LblRating" Text="" FontSize="16" TextColor="#FBC02D" />
                        <Label x:Name="LblReviewCount" Text="" FontSize="14" TextColor="Gray" />
                        <Label x:Name="LblSubtitle" FontSize="14" TextColor="Gray" HorizontalOptions="StartAndExpand" />
                    </HorizontalStackLayout>

                    <!-- Tabs: Tổng quan / Giới thiệu -->
                    <Grid ColumnDefinitions="*, *" Margin="0,6,0,0">
                        <Button x:Name="TabOverview" Text="Tổng quan" BackgroundColor="Transparent" TextColor="#00796B" FontAttributes="Bold" Clicked="OnTabOverviewClicked" />
                        <Button x:Name="TabIntro" Grid.Column="1" Text="Giới thiệu" BackgroundColor="Transparent" TextColor="Gray" Clicked="OnTabIntroClicked" />
                    </Grid>

                    <!-- Overview panel: the big 4 action buttons -->
                    <VerticalStackLayout x:Name="OverviewPanel" Spacing="8" Padding="0,8,0,0">
                        <!-- Action buttons: horizontal scroll to allow dragging/swiping when screen is small -->
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout Spacing="18" HorizontalOptions="Start" Padding="6">
                            <!-- Directions: pill button with icon + label -->
                            <Frame CornerRadius="28" Padding="10,8" BackgroundColor="#00796B" HasShadow="False" HorizontalOptions="Start" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="10">
                                    <Image Source="danduong.jpg" WidthRequest="20" HeightRequest="20" />
                                    <Label Text="Dẫn đường" TextColor="White" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer CommandParameter="directions" Tapped="OnGetDirectionsClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                    <!-- NOTE: audio/QR tools moved into narration action menu (opened via Thuyết minh) -->

                            <!-- Narration: open choices Audio / TTS -->
                            <Frame CornerRadius="28" Padding="10,8" BackgroundColor="#E0F7FA" HasShadow="False" HorizontalOptions="Start" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="10">
                                    <Image Source="thuyetminh.jpg" WidthRequest="20" HeightRequest="20" />
                                    <Label Text="Thuyết minh" TextColor="#00796B" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStartNarrationClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                            <!-- Share -->
                            <Frame CornerRadius="28" Padding="10,8" BackgroundColor="#E8F5E9" HasShadow="False" HorizontalOptions="Start" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="10">
                                    <Image Source="chia_se.jpg" WidthRequest="20" HeightRequest="20" />
                                    <Label Text="Chia sẻ" TextColor="#2E7D32" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnShareClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                            <!-- Save -->
                            <Frame CornerRadius="28" Padding="10,8" BackgroundColor="#FFF3E0" HasShadow="False" HorizontalOptions="Start" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="10">
                                    <Image Source="luu.jpg" WidthRequest="20" HeightRequest="20" />
                                    <Label Text="Lưu" TextColor="#EF6C00" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSaveClicked" />
                                </Frame.GestureRecognizers>
                            </Frame>

                            <!-- QR -->
                            <Frame CornerRadius="28" Padding="10,8" BackgroundColor="#E8F5E9" HasShadow="False" HorizontalOptions="Start" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="10">
                                    <Image Source="qr_icon.png" WidthRequest="20" HeightRequest="20" />
                                    <Label Text="Mã QR" TextColor="#2E7D32" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnShowQrClicked_Map" />
                                </Frame.GestureRecognizers>
                            </Frame>
                            </HorizontalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>

                    <!-- Introduction panel (description) -->
                    <VerticalStackLayout x:Name="IntroPanel" IsVisible="False" Spacing="6">
                        <Label x:Name="LblDescription" FontSize="14" TextColor="Gray" LineBreakMode="WordWrap" />
                        <Button x:Name="BtnToggleDescription" Text="Xem thêm" BackgroundColor="Transparent" TextColor="#1A73E8" Clicked="OnToggleDescriptionClicked" HorizontalOptions="Start" />
                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,8" />

                    <!-- Additional info rows -->
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                            <Label Text="📍" FontSize="18" />
                            <Label x:Name="LblAddress" FontSize="14" TextColor="Gray" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout VerticalOptions="Center" Spacing="8" Padding="0,4,0,0">
                            <Label Text="🕒" FontSize="18" />
                            <Label x:Name="LblOpeningHours" FontSize="14" TextColor="Gray" />
                            <Label x:Name="LblOpenStatus" FontSize="14" TextColor="#388E3C" HorizontalOptions="End" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout VerticalOptions="Center" Spacing="8" Padding="0,4,0,0">
                            <Label Text="🔗" FontSize="18" />
                            <Label x:Name="LblWebsite" FontSize="14" TextColor="#1A73E8" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout VerticalOptions="Center" Spacing="8" Padding="0,4,0,0">
                            <Label Text="📞" FontSize="18" />
                            <Label x:Name="LblPhone" FontSize="14" TextColor="Gray" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout VerticalOptions="Center" Spacing="8" Padding="0,4,0,0">
                            <Label Text="⭐" FontSize="18" />
                            <Label x:Name="LblReviewsSummary" FontSize="14" TextColor="Gray" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Frame>

        <!-- TRACKING CONTROL PANEL -->
        <Frame VerticalOptions="End" HorizontalOptions="Start" Margin="15,0,0,200" Padding="8" CornerRadius="12" BackgroundColor="#CCFFFFFF" IsVisible="False">
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout Spacing="8">
                    <Button x:Name="BtnStartTracking" Text="Start" Clicked="OnStartTrackingClicked" BackgroundColor="#1A73E8" TextColor="White" />
                    <Button x:Name="BtnStopTracking" Text="Stop" Clicked="OnStopTrackingClicked" BackgroundColor="#BDBDBD" TextColor="Black" IsEnabled="False" />
                </HorizontalStackLayout>
                <Label x:Name="LblTrackingStatus" Text="Status: stopped" FontSize="12" TextColor="Black"/>
                <CollectionView x:Name="CvLog" HeightRequest="120">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding .}" FontSize="12" TextColor="Black" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Frame>

        <!-- SHOW SAVED POIS BUTTON (CENTER BOTTOM) -->
        <Button x:Name="BtnShowSaved"
                IsVisible="False"
                Text="Hiện những địa điểm đã lưu"
                FontSize="14"
                BackgroundColor="#673AB7"
                TextColor="White"
                CornerRadius="20"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,140"
                Padding="14,8"
                Clicked="OnShowSavedClicked"/>

    </Grid>
</ContentPage>