@page
@model VinhKhanh.OwnerPortal.Pages.RegisterModel

<h2>Đăng ký chủ quán</h2>
<form method="post">
    <div>
        <label>Email</label>
        <input name="Email" />
    </div>
    <div>
        <label>Password</label>
        <input type="password" name="Password" />
    </div>
    <div>
        <label>Tên quán</label>
        <input name="ShopName" />
    </div>
    <div>
        <label>Địa chỉ</label>
        <input name="ShopAddress" />
    </div>
    <div>
        <label>CCCD</label>
        <input name="Cccd" />
    </div>
    <button type="submit">Đăng ký</button>
</form>
