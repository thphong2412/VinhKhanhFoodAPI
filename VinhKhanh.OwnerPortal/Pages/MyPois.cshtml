@page
@model VinhKhanh.OwnerPortal.Pages.MyPoisModel
@{
    ViewData["Title"] = "POI của tôi";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-list"></i> POI của tôi</h2>
        </div>
        <div class="col-auto">
            <a href="/CreatePoi" class="btn btn-warning">
                <i class="bi bi-plus-circle"></i> Tạo POI mới
            </a>
        </div>
    </div>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <input class="form-control" name="poiId" type="number" min="1" placeholder="Lọc theo ID POI" value="@Model.PoiIdFilter" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100" type="submit">Lọc</button>
        </div>
        <div class="col-md-2">
            <a class="btn btn-outline-light border w-100" href="/MyPois">Xóa lọc</a>
        </div>
    </form>

    <!-- Approved POIs -->
    @if (Model.ApprovedPois?.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="bi bi-check-circle"></i> POI đã duyệt (@Model.ApprovedPois.Count)
                </h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Tên POI</th>
                                <th>Danh mục</th>
                                <th>Vị trí</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var poi in Model.ApprovedPois)
                        {
                            <tr data-poi-id="@poi.Id">
                                <td><span class="badge bg-primary">@poi.Id</span></td>
                                <td><strong>@poi.Name</strong></td>
                                <td><span class="badge bg-info">@poi.Category</span></td>
                                <td>(@poi.Latitude, @poi.Longitude)</td>
                                <td>
                                    @{
                                        VinhKhanh.OwnerPortal.Pages.PoiRegistrationDto? req = null;
                                        var hasReq = Model.LatestRequestByPoiId.TryGetValue(poi.Id, out req);
                                    }
                                    @if (hasReq && req?.Status == "pending")
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-hourglass-split"></i> Đang ẩn (chờ duyệt)</span>
                                    }
                                    else if (poi.IsPublished)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Hiển thị</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-eye-slash"></i> Đang ẩn</span>
                                    }
                                </td>
                                <td>
                                    <a href="/PoiDetails/@poi.Id" class="btn btn-sm btn-info" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i> Chi tiết
                                    </a>
                                    <a href="/EditPoi/@poi.Id" class="btn btn-sm btn-warning" title="Sửa POI">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <a href="/OwnerAudio/@poi.Id" class="btn btn-sm btn-secondary" title="Audio">
                                        <i class="bi bi-music-note"></i> Audio
                                    </a>
                                    <a href="/OwnerTranslations/@poi.Id" class="btn btn-sm btn-light" title="Bản dịch">
                                        <i class="bi bi-translate"></i> Bản dịch
                                    </a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Pending POIs -->
    @if (Model.PendingPois?.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header bg-warning text-white">
                <h5 class="mb-0">
                    <i class="bi bi-hourglass-split"></i> Chờ duyệt (@Model.PendingPois.Count)
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Admin đang xem xét các POI này. Vui lòng đợi...
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Tên POI</th>
                                <th>Danh mục</th>
                                <th>Ngày tạo</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var poi in Model.PendingPois)
                        {
                            var displayPoiId = poi.TargetPoiId ?? poi.ApprovedPoiId ?? poi.Id;
                            <tr data-poi-id="@poi.Id">
                                <td><span class="badge bg-primary">@displayPoiId</span></td>
                                <td><strong>@poi.Name</strong></td>
                                <td><span class="badge bg-info">@poi.Category</span></td>
                                <td><small class="text-muted">@poi.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</small></td>
                                <td><span class="badge bg-warning"><i class="bi bi-hourglass-split"></i> Chờ duyệt</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Rejected POIs -->
    @if (Model.RejectedPois?.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">
                    <i class="bi bi-x-circle"></i> Bị từ chối (@Model.RejectedPois.Count)
                </h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Tên POI</th>
                                <th>Danh mục</th>
                                <th>Lý do</th>
                                <th>Ngày từ chối</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var poi in Model.RejectedPois)
                        {
                            var displayPoiId = poi.TargetPoiId ?? poi.ApprovedPoiId ?? poi.Id;
                            <tr data-poi-id="@poi.Id">
                                <td><span class="badge bg-primary">@displayPoiId</span></td>
                                <td><strong>@poi.Name</strong></td>
                                <td><span class="badge bg-info">@poi.Category</span></td>
                                <td>@poi.ReviewNotes</td>
                                <td><small class="text-muted">@poi.ReviewedAt?.ToString("dd/MM/yyyy HH:mm")</small></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Empty State -->
    @if ((Model.ApprovedPois?.Count ?? 0) == 0 && (Model.PendingPois?.Count ?? 0) == 0 && (Model.RejectedPois?.Count ?? 0) == 0)
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
            <p class="mt-3">Bạn chưa tạo POI nào</p>
            <a href="/CreatePoi" class="btn btn-warning">
                <i class="bi bi-plus-circle"></i> Tạo POI đầu tiên
            </a>
        </div>
    }
</div>
