@page
@model VinhKhanh.OwnerPortal.Pages.CreatePoiModel
@{
    ViewData["Title"] = "Tạo POI mới";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Tạo POI mới</h4>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="bi bi-exclamation-circle"></i> <strong>Lỗi:</strong>
                            @Html.ValidationSummary(true, "", new { @class = "mb-0" })
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" enctype="multipart/form-data" class="row g-3">
                        <h3>Thông tin cơ bản</h3>

                        <div class="col-md-6">
                            <label class="form-label" for="Name">Tên POI <span class="text-danger">*</span></label>
                            <input class="form-control" id="Name" name="Name" value="@Model.Name" required placeholder="Ví dụ: Ốc Oanh 534" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="Category">Loại (Category)</label>
                            <select class="form-select" id="Category" name="Category" required>
                                <option value="">-- Chọn danh mục --</option>
                                <option value="Food" selected="@(Model.Category == "Food")">Ăn uống (Food)</option>
                                <option value="Restaurant" selected="@(Model.Category == "Restaurant")">Nhà hàng (Restaurant)</option>
                                <option value="Attraction" selected="@(Model.Category == "Attraction")">Điểm du lịch (Attraction)</option>
                                <option value="Shopping" selected="@(Model.Category == "Shopping")">Mua sắm (Shopping)</option>
                                <option value="Hotel" selected="@(Model.Category == "Hotel")">Khách sạn (Hotel)</option>
                                <option value="Other" selected="@(Model.Category == "Other")">Khác (Other)</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Vĩ độ (Latitude)</label>
                            <input class="form-control" type="number" step="any" id="Latitude" name="Latitude" value="@(Model.Latitude == 0 ? "" : Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture))" required placeholder="10.775" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Kinh độ (Longitude)</label>
                            <input class="form-control" type="number" step="any" id="Longitude" name="Longitude" value="@(Model.Longitude == 0 ? "" : Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture))" required placeholder="106.584" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bán kính (mét)</label>
                            <input class="form-control" type="number" id="Radius" name="Radius" value="@Model.Radius" required />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Ưu tiên (Priority)</label>
                            <input class="form-control" type="number" id="Priority" name="Priority" value="@Model.Priority" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Cooldown (giây)</label>
                            <input class="form-control" type="number" id="CooldownSeconds" name="CooldownSeconds" value="@Model.CooldownSeconds" />
                        </div>

                        <h3 class="mt-4">Hình ảnh (3-4 ảnh)</h3>
                        <div class="col-12">
                            <label class="form-label">📸 Tải ảnh (chọn nhiều file)</label>
                            <input class="form-control" type="file" id="ImageFiles" name="ImageFiles" multiple accept="image/*" />
                            <small class="text-muted">Chọn 3-4 ảnh PNG/JPG. App sẽ hiển thị carousel</small>
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="WebsiteUrl">Website</label>
                            <input class="form-control" id="WebsiteUrl" name="WebsiteUrl" value="@Model.WebsiteUrl" placeholder="https://..." />
                        </div>

                        <h3 class="mt-4">Chi tiết</h3>

                        <div class="col-md-6">
                            <label class="form-label" for="ContentTitle">Tiêu đề</label>
                            <input class="form-control" id="ContentTitle" name="ContentTitle_VI" value="@Model.ContentTitle" placeholder="Tên hiển thị chi tiết" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="ContentSubtitle">Phụ đề</label>
                            <input class="form-control" id="ContentSubtitle" name="ContentSubtitle_VI" value="@Model.ContentSubtitle" placeholder="Mô tả ngắn" />
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="ContentDescription">Mô tả</label>
                            <textarea class="form-control" id="ContentDescription" name="ContentDescription_VI" rows="3" placeholder="Mô tả chi tiết">@Model.ContentDescription</textarea>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label" for="ContentPriceMin">Giá tối thiểu</label>
                            <input class="form-control" id="ContentPriceMin" name="ContentPriceMin_VI" value="@Model.ContentPriceMin" placeholder="Ví dụ: 45.000 VND" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="ContentPriceMax">Giá tối đa</label>
                            <input class="form-control" id="ContentPriceMax" name="ContentPriceMax_VI" value="@Model.ContentPriceMax" placeholder="Ví dụ: 100.000 VND" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label" for="ContentRating">Đánh giá</label>
                            <input class="form-control" type="number" id="ContentRating" name="ContentRating_VI" value="@Model.ContentRating" step="0.1" min="0" max="5" placeholder="4.5" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="ContentOpenTime">Giờ mở cửa</label>
                            <input class="form-control" id="ContentOpenTime" name="ContentOpenTime_VI" value="@Model.ContentOpenTime" placeholder="10:00" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="ContentCloseTime">Giờ đóng cửa</label>
                            <input class="form-control" id="ContentCloseTime" name="ContentCloseTime_VI" value="@Model.ContentCloseTime" placeholder="22:00" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label" for="ContentPhoneNumber">Số điện thoại</label>
                            <input class="form-control" id="ContentPhoneNumber" name="ContentPhoneNumber_VI" value="@Model.ContentPhoneNumber" placeholder="0123456789" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label" for="ContentAddress">Địa chỉ</label>
                            <input class="form-control" id="ContentAddress" name="ContentAddress_VI" value="@Model.ContentAddress" placeholder="Số nhà, đường, phường..." />
                        </div>

                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-warning btn-lg flex-grow-1">
                                <i class="bi bi-check-circle"></i> Gửi để duyệt
                            </button>
                            <a href="/OwnerDashboard" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>

                        <div class="col-12 alert alert-info mt-3">
                            <i class="bi bi-info-circle"></i> 
                            <strong>Lưu ý:</strong> POI sẽ được gửi để admin duyệt trước khi hiển thị trong hệ thống.
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
}
