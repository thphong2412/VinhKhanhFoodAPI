@page "/OwnerTranslations/{poiId:int}"
@model VinhKhanh.OwnerPortal.Pages.OwnerTranslationsModel
@{
    ViewData["Title"] = "Bản dịch POI";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🌐 Bản dịch của POI #@Model.PoiId</h2>
        <a href="/PoiDetails/@Model.PoiId" class="btn btn-secondary">← Quay lại chi tiết</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="alert alert-info">
        Chủ quán gửi bản dịch mới sẽ ở trạng thái chờ admin duyệt. Trong lúc chờ duyệt, POI sẽ hiển thị trạng thái đang ẩn.
    </div>

    <div class="card mb-4">
        <div class="card-header bg-warning"><strong>Gửi yêu cầu cập nhật bản dịch</strong></div>
        <div class="card-body">
            <form method="post" asp-page-handler="SubmitTranslationUpdate">
                <input type="hidden" name="poiId" value="@Model.PoiId" />
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Ngôn ngữ</label>
                        <select class="form-control" name="languageCode" required>
                            <option value="en">English (en)</option>
                            <option value="ja">日本語 (ja)</option>
                            <option value="ko">한국어 (ko)</option>
                            <option value="zh">中文 (zh)</option>
                            <option value="ru">Русский (ru)</option>
                            <option value="th">ไทย (th)</option>
                            <option value="es">Español (es)</option>
                        </select>
                    </div>
                    <div class="col-md-9">
                        <label class="form-label">Tiêu đề</label>
                        <input class="form-control" name="title" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phụ đề</label>
                        <input class="form-control" name="subtitle" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Địa chỉ</label>
                        <input class="form-control" name="address" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Mô tả</label>
                        <textarea class="form-control" name="description" rows="3"></textarea>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Giá min</label>
                        <input class="form-control" name="priceMin" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Giá max</label>
                        <input class="form-control" name="priceMax" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Rating</label>
                        <input class="form-control" type="number" step="0.1" name="rating" min="0" max="5" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Mở cửa</label>
                        <input class="form-control" name="openTime" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Đóng cửa</label>
                        <input class="form-control" name="closeTime" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">SĐT</label>
                        <input class="form-control" name="phoneNumber" />
                    </div>
                    <div class="col-md-8 d-flex align-items-end">
                        <button class="btn btn-warning w-100">Gửi admin duyệt bản dịch</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-primary text-white"><strong>Danh sách nội dung theo ngôn ngữ</strong></div>
        <div class="card-body">
            @if (Model.Contents == null || Model.Contents.Count == 0)
            {
                <div class="alert alert-warning mb-0">POI này chưa có nội dung dịch.</div>
            }
            else
            {
                @foreach (var c in Model.Contents)
                {
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between mb-2">
                            <strong>Ngôn ngữ: @(c.LanguageCode?.ToUpper() ?? "N/A")</strong>
                            <span class="badge bg-secondary">ID content #@c.Id</span>
                        </div>
                        <div><strong>Tiêu đề:</strong> @c.Title</div>
                        <div><strong>Mô tả:</strong> @c.Description</div>
                        <div><strong>Giá:</strong> @c.PriceRange</div>
                        <div><strong>Giờ mở cửa:</strong> @c.OpeningHours</div>
                        <div><strong>Địa chỉ:</strong> @c.Address</div>
                    </div>
                }
            }
        </div>
    </div>
</div>
