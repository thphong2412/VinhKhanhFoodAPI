@page "/PoiDetails/{id:int}"
@model VinhKhanh.OwnerPortal.Pages.PoiDetailsModel
@{
    ViewData["Title"] = "Chi tiết POI";
    var apiBaseUrl = (Model.ApiBaseUrl ?? string.Empty).Trim();

    string ResolveImageUrl(string raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        if (Uri.TryCreate(raw, UriKind.Absolute, out _)) return raw;
        if (string.IsNullOrWhiteSpace(apiBaseUrl)) return raw;
        return $"{apiBaseUrl.TrimEnd('/')}/{raw.TrimStart('/')}";
    }
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Chi tiết POI: <strong>@Model.Poi.Name</strong></h2>
        <a href="/MyPois" class="btn btn-secondary">← Quay lại</a>
    </div>

    <div class="row">
        <!-- Main Content -->
        <div class="col-md-8">
            <!-- Basic Info -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin cơ bản</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p><strong>ID:</strong> <span class="badge bg-primary">@Model.Poi.Id</span></p>
                            <p><strong>Tên:</strong> @Model.Poi.Name</p>
                            <p><strong>Danh mục:</strong> <span class="badge bg-info">@Model.Poi.Category</span></p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Tọa độ:</strong> (@Model.Poi.Latitude, @Model.Poi.Longitude)</p>
                            <p><strong>Bán kính:</strong> @Model.Poi.Radius m</p>
                            <p><strong>Độ ưu tiên:</strong> @Model.Poi.Priority</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Image -->
            @if (!string.IsNullOrEmpty(Model.Poi.ImageUrl))
            {
                var imageUrls = Model.Poi.ImageUrl
                    .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Where(x => !string.IsNullOrWhiteSpace(x))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList();

                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-image"></i> Hình ảnh</h5>
                    </div>
                    <div class="card-body text-center">
                        @if (imageUrls.Count <= 1)
                        {
                            <img src="@ResolveImageUrl(imageUrls.FirstOrDefault() ?? string.Empty)" alt="@Model.Poi.Name" class="img-fluid" style="max-height: 400px; border-radius: 8px;">
                        }
                        else
                        {
                            var carouselId = $"ownerPoiImgCarousel_{Model.Poi.Id}";
                            <div id="@carouselId" class="carousel slide" data-bs-ride="carousel">
                                <div class="carousel-inner rounded">
                                    @for (var i = 0; i < imageUrls.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : null)">
                                            <img src="@ResolveImageUrl(imageUrls[i])" class="d-block w-100" alt="@Model.Poi.Name" style="max-height: 420px; object-fit: cover;">
                                        </div>
                                    }
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                                    <span class="carousel-control-next-icon"></span>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Links -->
            @if (!string.IsNullOrEmpty(Model.Poi.WebsiteUrl) || !string.IsNullOrEmpty(Model.Poi.QrCode))
            {
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-link-45deg"></i> Liên kết</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.Poi.WebsiteUrl))
                        {
                            <p><strong>Website:</strong> <a href="@Model.Poi.WebsiteUrl" target="_blank">@Model.Poi.WebsiteUrl</a></p>
                        }
                        @if (!string.IsNullOrEmpty(Model.Poi.QrCode))
                        {
                            var qrRenderUrl = $"https://quickchart.io/qr?size=360&margin=1&text={Uri.EscapeDataString(Model.Poi.QrCode)}";
                            <p><strong>QR Code:</strong></p>
                            <div class="d-flex align-items-center gap-3 flex-wrap">
                                <a href="@Model.Poi.QrCode" target="_blank" class="btn btn-sm btn-outline-primary">Mở liên kết QR</a>
                                <a href="@qrRenderUrl" target="_blank">
                                    <img src="@qrRenderUrl" alt="QR @Model.Poi.Name" style="width:140px;height:140px;border:1px solid #ddd;border-radius:8px;" />
                                </a>
                            </div>
                            <small class="text-muted d-block mt-2">Payload: @Model.Poi.QrCode</small>
                        }
                    </div>
                </div>
            }

            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-translate"></i> Nội dung & bản dịch</h5>
                </div>
                <div class="card-body">
                    @if (Model.Contents == null || Model.Contents.Count == 0)
                    {
                        <div class="alert alert-warning mb-0">POI này chưa có nội dung/bản dịch.</div>
                    }
                    else
                    {
                        foreach (var c in Model.Contents.OrderBy(x => x.LanguageCode))
                        {
                            <div class="border rounded p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <strong>@(string.IsNullOrWhiteSpace(c.LanguageCode) ? "(unknown)" : c.LanguageCode.ToUpperInvariant())</strong>
                                    <small class="text-muted">@c.GetNormalizedPriceRangeDisplay()</small>
                                </div>
                                <div><strong>Tiêu đề:</strong> @c.Title</div>
                                <div><strong>Phụ đề:</strong> @c.Subtitle</div>
                                <div><strong>Mô tả:</strong> @c.Description</div>
                                <div class="row mt-2">
                                    <div class="col-md-4"><strong>Rating:</strong> @c.Rating</div>
                                    <div class="col-md-4"><strong>Giờ:</strong> @c.OpeningHours</div>
                                    <div class="col-md-4"><strong>SĐT:</strong> @c.PhoneNumber</div>
                                </div>
                                <div class="mt-1"><strong>Địa chỉ:</strong> @c.Address</div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-music-note"></i> Audio hiện có</h5>
                </div>
                <div class="card-body">
                    @if (Model.Audios == null || Model.Audios.Count == 0)
                    {
                        <div class="alert alert-warning mb-0">POI này chưa có audio.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Lang</th>
                                        <th>Loại</th>
                                        <th>Nghe thử</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var a in Model.Audios.OrderBy(x => x.LanguageCode).ThenBy(x => x.IsTts))
                                    {
                                        <tr>
                                            <td>@a.Id</td>
                                            <td>@a.LanguageCode</td>
                                            <td>@(a.IsTts ? "TTS" : "Upload")</td>
                                            <td>
                                                <audio controls style="width:220px;">
                                                    <source src="@(ResolveImageUrl(a.Url))" type="audio/mpeg" />
                                                </audio>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Map -->
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Vị trí trên bản đồ</h5>
                </div>
                <div class="card-body">
                    <div id="map" style="height: 400px; border-radius: 8px; border: 1px solid #ddd;"></div>
                    <small class="text-muted mt-2 d-block">
                        Tọa độ: @Model.Poi.Latitude, @Model.Poi.Longitude
                    </small>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-md-4">
            <!-- Status -->
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-check-circle"></i> Trạng thái</h5>
                </div>
                <div class="card-body">
                    @if (Model.Poi.IsPublished)
                    {
                        <span class="badge bg-success" style="font-size: 1rem; padding: 0.5rem 1rem;">
                            <i class="bi bi-check-circle"></i> Đã duyệt
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning" style="font-size: 1rem; padding: 0.5rem 1rem;">
                            <i class="bi bi-clock"></i> Chưa duyệt
                        </span>
                    }
                </div>
            </div>

            <!-- Configuration -->
            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-sliders"></i> Cấu hình</h5>
                </div>
                <div class="card-body">
                    <p class="small mb-2"><strong>Cooldown:</strong> @Model.Poi.CooldownSeconds giây</p>
                    <p class="small mb-2"><strong>Bán kính:</strong> @Model.Poi.Radius m</p>
                    <p class="small mb-0"><strong>Độ ưu tiên:</strong> @Model.Poi.Priority</p>
                </div>
            </div>

            <!-- Actions -->
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h5 class="mb-0"><i class="bi bi-gear"></i> Hành động</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/MyPois" class="btn btn-outline-secondary w-100">← Quay lại danh sách</a>
                        <a href="/EditPoi/@Model.Poi.Id" class="btn btn-warning w-100">📝 Sửa (gửi admin duyệt)</a>
                        <a href="/OwnerAudio/@Model.Poi.Id" class="btn btn-secondary w-100">🎵 Audio</a>
                        <a href="/OwnerTranslations/@Model.Poi.Id" class="btn btn-light w-100">🌐 Bản dịch</a>
                        <form method="post" asp-page-handler="RequestDelete" asp-route-id="@Model.Poi.Id" onsubmit="return confirm('Gửi yêu cầu xóa POI này cho admin duyệt?');">
                            <button type="submit" class="btn btn-danger w-100">🗑 Gửi yêu cầu xóa (chờ duyệt)</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script>
        // Initialize Map
        const map = L.map('map').setView([@Model.Poi.Latitude, @Model.Poi.Longitude], 15);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19
        }).addTo(map);

        // Add Marker
        const marker = L.marker([@Model.Poi.Latitude, @Model.Poi.Longitude])
            .addTo(map)
            .bindPopup('<b>@Model.Poi.Name</b>')
            .openPopup();

        // Draw Radius Circle
        const circle = L.circle([@Model.Poi.Latitude, @Model.Poi.Longitude], {
            radius: @Model.Poi.Radius,
            color: '#e67e22',
            fillColor: '#e67e22',
            fillOpacity: 0.1,
            weight: 2
        }).addTo(map);
    </script>
}
