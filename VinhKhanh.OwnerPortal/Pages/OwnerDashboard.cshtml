@page
@using System.Text.Json
@model VinhKhanh.OwnerPortal.Pages.OwnerDashboardModel
@{
    ViewData["Title"] = "Dashboard";
    var engagementByPoi = Model.Engagements?.ToDictionary(e => e.PoiId) ?? new Dictionary<int, VinhKhanh.OwnerPortal.Pages.OwnerDashboardModel.AnalyticsEngagementPoi>();
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-speedometer2"></i> Dashboard</h2>
            <p class="text-muted">Chào mừng, Owner #@Model.UserId</p>
        </div>
        <div class="col-auto">
            <form method="post" style="display:inline;">
                <button type="submit" asp-page-handler="Logout" class="btn btn-outline-danger">
                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                </button>
            </form>
        </div>
    </div>

    @if (!Model.IsVerified)
    {
        <div class="alert alert-warning alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> 
            <strong>Chưa được phê duyệt!</strong> 
            Tài khoản của bạn đang chờ admin duyệt. Vui lòng đợi...
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    else
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> 
            <strong>Tài khoản đã được phê duyệt!</strong>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-2 col-6">
            <div class="card border-primary h-100 shadow-sm">
                <div class="card-body bg-primary text-white rounded-2">
                    <div class="small opacity-75">POI của bạn</div>
                    <div class="display-6 fw-bold mb-0">@Model.TotalPois</div>
                </div>
            </div>
        </div>
        <div class="col-md-2 col-6">
            <div class="card border-danger h-100 shadow-sm">
                <div class="card-body bg-danger text-white rounded-2">
                    <div class="small opacity-75">POI HOT</div>
                    <div class="display-6 fw-bold mb-0">@Model.TotalHotPois</div>
                </div>
            </div>
        </div>
        <div class="col-md-2 col-6">
            <div class="card border-success h-100 shadow-sm">
                <div class="card-body bg-success text-white rounded-2">
                    <div class="small opacity-75">Đang ở quán</div>
                    <div class="display-6 fw-bold mb-0">@Model.TotalActiveUsers</div>
                </div>
            </div>
        </div>
        <div class="col-md-2 col-6">
            <div class="card border-info h-100 shadow-sm">
                <div class="card-body bg-info text-white rounded-2">
                    <div class="small opacity-75">Lượt nghe</div>
                    <div class="display-6 fw-bold mb-0">@Model.TotalListens</div>
                </div>
            </div>
        </div>
        <div class="col-md-2 col-6">
            <div class="card border-secondary h-100 shadow-sm">
                <div class="card-body bg-dark text-white rounded-2">
                    <div class="small opacity-75">Đã ghé</div>
                    <div class="display-6 fw-bold mb-0">@Model.TotalVisitedUsers</div>
                </div>
            </div>
        </div>
        <div class="col-md-2 col-6">
            <div class="card border-warning h-100 shadow-sm">
                <div class="card-body bg-warning text-dark rounded-2">
                    <div class="small">QR scan</div>
                    <div class="display-6 fw-bold mb-0">@Model.TotalQrScans</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-dark text-white">
            <strong><i class="bi bi-stars"></i> Top POI hiệu quả nhất (theo conversion score)</strong>
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>POI</th>
                        <th>HOT</th>
                        <th>Đang ở đó</th>
                        <th>Đã ghé</th>
                        <th>QR</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.TopOwnerPois?.Any() == true)
                {
                    foreach (var s in Model.TopOwnerPois)
                    {
                        <tr>
                            <td><strong>@s.PoiName</strong><br /><small class="text-muted">#@s.PoiId</small></td>
                            <td>
                                @if (s.IsHot)
                                {
                                    <span class="badge bg-danger">HOT</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">-</span>
                                }
                            </td>
                            <td><span class="badge bg-success">@s.ActiveUsers</span></td>
                            <td><span class="badge bg-primary">@s.VisitedUsers</span></td>
                            <td><span class="badge bg-warning text-dark">@s.QrScanCount</span></td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted">Chưa có dữ liệu hành vi cho POI của bạn</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Top POIs Table -->
    <div class="card mb-4">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0"><i class="bi bi-star"></i> Top POIs được nghe nhiều nhất</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>POI ID</th>
                        <th>Tên POI</th>
                        <th>Lượt nghe</th>
                        <th>Thông tin</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.TopListenedPois?.Any() == true)
                {
                    foreach (var item in Model.TopListenedPois)
                    {
                        <tr>
                            <td><span class="badge bg-primary">@item.PoiId</span></td>
                            <td>@(string.IsNullOrWhiteSpace(item.PoiName) ? "-" : item.PoiName)</td>
                            <td><span class="fw-bold text-success fs-5">@item.Count</span></td>
                            <td>
                                <a class="btn btn-sm btn-info" href="/PoiDetails/@item.PoiId">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" class="text-center text-muted">Chưa có dữ liệu lượt nghe</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Heatmap -->
    <div class="card mb-4">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Bản đồ nhiệt lượt nghe POI của bạn</h5>
        </div>
        <div class="card-body">
            <div id="ownerHeatmap" style="height: 420px; border-radius: 8px; border: 1px solid #ddd;"></div>
            <small class="text-muted d-block mt-2">Chỉ hiển thị POI của bạn (dựa trên lượt nghe TTS/Audio).</small>
        </div>
    </div>

    <!-- Engagement Table -->
    <div class="card mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-headphones"></i> Engagement theo POI (TTS/Audio/Chi tiết)</h5>
        </div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>
    <script>
        (function () {
            const poiPoints = @Html.Raw(JsonSerializer.Serialize(
                Model.OwnerPoiLocations?.Select(p =>
                {
                    engagementByPoi.TryGetValue(p.PoiId, out var e);
                    return new object[]
                    {
                        p.Latitude,
                        p.Longitude,
                        Math.Max(1, e?.TotalListens ?? 1),
                        string.IsNullOrWhiteSpace(p.PoiName) ? $"POI #{p.PoiId}" : p.PoiName,
                        p.PoiId,
                        e?.TtsPlays ?? 0,
                        e?.AudioPlays ?? 0
                    };
                }).ToList() ?? new List<object[]>()));

            const map = L.map('ownerHeatmap').setView([10.762622, 106.660172], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            if (poiPoints.length > 0) {
                const heatPoints = poiPoints.map(p => [p[0], p[1], Math.min(1, Math.max(0.2, p[2] / 20))]);
                L.heatLayer(heatPoints, {
                    radius: 24,
                    blur: 18,
                    maxZoom: 17,
                    gradient: { 0.4: '#ffe082', 0.7: '#ffb300', 1.0: '#e67e22' }
                }).addTo(map);

                if (poiPoints.length === 1) {
                    map.setView([poiPoints[0][0], poiPoints[0][1]], 16);
                } else {
                    const bounds = L.latLngBounds(poiPoints.map(p => [p[0], p[1]]));
                    map.fitBounds(bounds, { padding: [28, 28] });
                }
            }

            if (poiPoints.length > 0) {
                poiPoints.forEach(p => {
                    const poiTitle = `${p[3]} (ID: ${p[4]}) · TTS ${p[5]} · Audio ${p[6]}`;
                    L.circleMarker([p[0], p[1]], {
                        radius: 5,
                        color: '#111111',
                        fillColor: '#111111',
                        fillOpacity: 0.9,
                        weight: 1
                    }).addTo(map).bindTooltip(poiTitle, { direction: "top", offset: [0, -6], opacity: 0.9 });
                });
            }
        })();
    </script>
}
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>POI</th>
                            <th>Tổng lượt nghe</th>
                            <th>TTS</th>
                            <th>Audio MP3</th>
                            <th>Mở chi tiết</th>
                            <th>Users</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Engagements?.Any() == true)
                    {
                        foreach (var e in Model.Engagements)
                        {
                            <tr>
                                <td>
                                    <strong>@(string.IsNullOrWhiteSpace(e.PoiName) ? $"POI #{e.PoiId}" : e.PoiName)</strong>
                                    <br /><small class="text-muted">#@e.PoiId</small>
                                </td>
                                <td><span class="badge bg-success">@e.TotalListens</span></td>
                                <td><span class="badge bg-primary">@e.TtsPlays</span></td>
                                <td><span class="badge bg-info text-dark">@e.AudioPlays</span></td>
                                <td><span class="badge bg-warning text-dark">@e.DetailOpens</span></td>
                                <td><span class="badge bg-secondary">@e.UniqueUsers</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted">Chưa có dữ liệu Engagement</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-list" style="font-size: 2rem; color: #ffc107;"></i>
                    <h5 class="card-title mt-3">POI của tôi</h5>
                    <p class="card-text text-muted">Quản lý các POI đã tạo</p>
                    <a href="/MyPois" class="btn btn-warning">
                        <i class="bi bi-arrow-right"></i> Xem
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-plus-circle" style="font-size: 2rem; color: #ffc107;"></i>
                    <h5 class="card-title mt-3">Tạo POI mới</h5>
                    <p class="card-text text-muted">Thêm một POI mới vào hệ thống</p>
                    <a href="/CreatePoi" class="btn btn-warning">
                        <i class="bi bi-arrow-right"></i> Tạo
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Info Box -->
    <div class="card bg-light">
        <div class="card-body">
            <h6 class="card-title"><i class="bi bi-info-circle"></i> Thông tin hữu ích</h6>
            <ul class="small mb-0">
                <li>Mỗi POI mới bạn tạo sẽ được gửi để admin duyệt trước khi hiển thị</li>
                <li>Bạn có thể xem trạng thái duyệt của các POI trong mục "POI của tôi"</li>
                <li>Nếu POI bị từ chối, bạn sẽ thấy lý do và có thể tạo lại</li>
            </ul>
        </div>
    </div>
</div>
