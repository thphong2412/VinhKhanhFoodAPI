@{
    var title = ViewData["Title"] as string ?? "Vinh Khanh Admin";
    string currentPath = Context.Request.Path.ToString().ToLower();
    var isAdmin = Context?.User?.IsInRole("Admin") == true
        || string.Equals(Context?.User?.Identity?.Name, "admin", StringComparison.OrdinalIgnoreCase);
    var configuredApiBase = (Context?.RequestServices?.GetService(typeof(IConfiguration)) as IConfiguration)?["ApiBaseUrl"] ?? "http://localhost:5291/";
    var normalizedApiBase = configuredApiBase.EndsWith("/") ? configuredApiBase : configuredApiBase + "/";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f5f6f8; }
        .navbar { background: #ffffff; border-bottom: 1px solid #e9ecef; }
        .navbar-brand { color: #1f2937 !important; font-weight: 700; }
        .sidebar {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 10px rgba(0,0,0,.06);
            padding: 16px 10px;
            min-height: 90vh;
        }
        .sidebar .nav-link {
            color: #374151 !important;
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 4px;
            border-left: 4px solid transparent;
            background: #f8f9fa;
            transition: background 0.2s, color 0.2s, border 0.2s;
        }
        .sidebar .nav-link.active, .sidebar .nav-link[aria-current="page"] {
            background: #e9f2ff;
            color: #1d4ed8 !important;
            border-left: 4px solid #2563eb;
        }
        .sidebar .nav-link:hover {
            background: #eef2f7;
            color: #111827 !important;
        }
        .main-content { padding: 24px 12px; }
        .table thead { background: #f7f7f8; }
        .table-striped > tbody > tr:nth-of-type(odd) { background: #fcfcfd; }
        .btn-primary { background: #2563eb; border: none; }
        .btn-info { background: #0ea5a4; border: none; }
        .btn-danger { background: #dc2626; border: none; }
        .badge { background: #4b5563; }
        h1, h2, h3, h4 { color: #111827; }

        .admin-notify-wrap {
            position: relative;
            margin-right: 8px;
        }

        .admin-notify-btn {
            position: relative;
            width: 42px;
            height: 42px;
            border-radius: 999px;
            border: 1px solid #d1d5db;
            background: #fff;
            color: #1f2937;
            font-size: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .admin-notify-count {
            position: absolute;
            top: -5px;
            right: -5px;
            min-width: 18px;
            height: 18px;
            border-radius: 999px;
            background: #ef4444;
            color: #fff;
            font-size: 11px;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 0 5px;
            font-weight: 700;
        }

        .admin-notify-panel {
            width: min(420px, 92vw);
            max-height: 420px;
            overflow: auto;
            padding: 0;
        }

        .admin-notify-item {
            padding: 10px 12px;
            border-bottom: 1px solid #f1f5f9;
        }

        .admin-notify-item:last-child {
            border-bottom: 0;
        }

        .admin-notify-empty {
            padding: 14px;
            color: #6b7280;
            font-size: .9rem;
        }

        .admin-notify-time {
            color: #6b7280;
            font-size: .75rem;
        }
    </style>
    @RenderSection("Head", required: false)
</head>
<body>
    <div id="vk-config" data-api-base="@normalizedApiBase"></div>
    <nav class="navbar navbar-expand-lg mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/PoiAdmin">Vinh Khanh Admin</a>
            <div class="d-flex ms-auto">
                <div class="dropdown admin-notify-wrap">
                    <button class="admin-notify-btn" type="button" id="adminNotifyBtn" data-bs-toggle="dropdown" aria-expanded="false" title="Thông báo">
                        🔔
                        <span class="admin-notify-count" id="adminNotifyCount">0</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end admin-notify-panel" aria-labelledby="adminNotifyBtn">
                        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                            <strong>Thông báo</strong>
                            <button class="btn btn-sm btn-link p-0" type="button" id="adminNotifyClearBtn">Xóa tất cả</button>
                        </div>
                        <div id="adminNotifyList"></div>
                    </div>
                </div>
                <form method="post" action="/Account/Logout">
                    <button type="submit" class="btn btn-outline-secondary ms-2">Đăng xuất</button>
                </form>
            </div>
        </div>
    </nav>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 sidebar">
                <nav class="nav flex-column">
                    <a class="nav-link @(currentPath.StartsWith("/poiadmin") ? "active" : "")" href="/PoiAdmin">Quản lý POI</a>
                    <a class="nav-link @(currentPath.StartsWith("/adminmap") ? "active" : "")" href="/AdminMap">Bản đồ</a>
                    <a class="nav-link @(currentPath.StartsWith("/owneradmin") ? "active" : "")" href="/OwnerAdmin">Quản lý tài khoản Owner</a>
                    <a class="nav-link @(currentPath.StartsWith("/adminpoiregistrations") ? "active" : "")" href="/AdminPoiRegistrations/Pending">Chờ duyệt POI của Owner</a>
                    <a class="nav-link @(currentPath.StartsWith("/tracelogadmin") ? "active" : "")" href="/TraceLogAdmin">Lịch sử sử dụng</a>
                    <a class="nav-link @(currentPath.StartsWith("/analyticsadmin") ? "active" : "")" href="/AnalyticsAdmin">Analytics</a>
                    <a class="nav-link @(currentPath.StartsWith("/adminroutemap") ? "active" : "")" href="/AdminRouteMap">Tuyến di chuyển</a>
                    <a class="nav-link @(currentPath.StartsWith("/touradmin") ? "active" : "")" href="/TourAdmin">Quản lý tour</a>
                </nav>
            </div>
            <div class="col-md-10 main-content">
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        const cfgRoot = document.getElementById("vk-config");
        const apiBaseUrl = (cfgRoot?.dataset?.apiBase || "http://localhost:5291/").replace(/\/$/, "");
        const notifyStorageKey = "vk_admin_notifications_v1";
        let adminNotifications = [];
        let unreadNotifications = 0;

        function loadNotifications() {
            try {
                const raw = localStorage.getItem(notifyStorageKey);
                adminNotifications = raw ? JSON.parse(raw) : [];
                if (!Array.isArray(adminNotifications)) adminNotifications = [];
                adminNotifications = adminNotifications.slice(0, 50);
            } catch {
                adminNotifications = [];
            }
        }

        function saveNotifications() {
            try {
                localStorage.setItem(notifyStorageKey, JSON.stringify(adminNotifications.slice(0, 50)));
            } catch { }
        }

        function formatNotifyTime(ts) {
            try {
                const dt = new Date(ts);
                return dt.toLocaleString("vi-VN");
            } catch {
                return "";
            }
        }

        function renderNotifications() {
            const list = document.getElementById("adminNotifyList");
            const badge = document.getElementById("adminNotifyCount");
            if (!list || !badge) return;

            if (!adminNotifications.length) {
                list.innerHTML = '<div class="admin-notify-empty">Chưa có thông báo mới.</div>';
            } else {
                list.innerHTML = adminNotifications.map(item => {
                    return `<div class="admin-notify-item">
                        <div>${item.message}</div>
                        <div class="admin-notify-time">${formatNotifyTime(item.timestamp)}</div>
                    </div>`;
                }).join("");
            }

            if (unreadNotifications > 0) {
                badge.style.display = "inline-flex";
                badge.textContent = unreadNotifications > 99 ? "99+" : unreadNotifications;
            } else {
                badge.style.display = "none";
            }
        }

        function pushNotification(message) {
            if (!message) return;
            adminNotifications.unshift({
                message,
                timestamp: new Date().toISOString()
            });
            adminNotifications = adminNotifications.slice(0, 50);
            unreadNotifications = Math.min(999, unreadNotifications + 1);
            saveNotifications();
            renderNotifications();
        }

        function setupNotificationUiEvents() {
            const notifyBtn = document.getElementById("adminNotifyBtn");
            const clearBtn = document.getElementById("adminNotifyClearBtn");
            if (notifyBtn) {
                notifyBtn.addEventListener("click", () => {
                    unreadNotifications = 0;
                    renderNotifications();
                });
            }

            if (clearBtn) {
                clearBtn.addEventListener("click", (e) => {
                    e.preventDefault();
                    adminNotifications = [];
                    unreadNotifications = 0;
                    saveNotifications();
                    renderNotifications();
                });
            }
        }

        // ✅ Real-time sync for Admin Portal
        const connection = new signalR.HubConnectionBuilder()
            .withUrl(`${apiBaseUrl}/sync`)
            .withAutomaticReconnect()
            .build();

        connection.on("PoiAdded", (poi) => {
            console.log("[SignalR] POI Added:", poi);
            showNotification(`POI mới: ${poi.name}`, "success");
            pushNotification(`Owner/Admin vừa thêm POI: ${poi.name || "N/A"}`);
            // Optionally refresh POI list if on that page
            if (window.location.pathname.includes("/PoiAdmin")) {
                location.reload();
            }
        });

        connection.on("PoiUpdated", (poi) => {
            console.log("[SignalR] POI Updated:", poi);
            showNotification(`POI cập nhật: ${poi.name}`, "info");
            pushNotification(`POI vừa được chỉnh sửa: ${poi.name || "N/A"}`);
            if (window.location.pathname.includes("/PoiAdmin")) {
                // Update table row without full reload
                updatePoiInTable(poi.id, poi);
            }
        });

        connection.on("PoiDeleted", (poiId) => {
            console.log("[SignalR] POI Deleted:", poiId);
            showNotification(`POI bị xóa (ID: ${poiId})`, "warning");
            pushNotification(`POI vừa bị xóa (ID: ${poiId})`);
            if (window.location.pathname.includes("/PoiAdmin")) {
                removePoiFromTable(poiId);
            }
        });

        connection.on("ContentCreated", (data) => {
            console.log("[SignalR] Content Created:", data);
            showNotification(`Nội dung mới: ${data.title || "N/A"}`, "success");
            pushNotification(`Có bản dịch/nội dung mới: ${data.title || "N/A"}`);
        });

        connection.on("ContentUpdated", (data) => {
            console.log("[SignalR] Content Updated:", data);
            showNotification(`Nội dung cập nhật: ${data.title || "N/A"}`, "info");
            pushNotification(`Có cập nhật bản dịch/nội dung: ${data.title || "N/A"}`);
        });

        connection.on("ContentDeleted", (contentId) => {
            console.log("[SignalR] Content Deleted:", contentId);
            showNotification(`Nội dung bị xóa (ID: ${contentId})`, "warning");
            pushNotification(`Có nội dung/bản dịch bị xóa (ID: ${contentId})`);
        });

        connection.on("AudioUploaded", (data) => {
            console.log("[SignalR] Audio Uploaded:", data);
            showNotification(`Audio tải lên: ${data.languageCode}`, "success");
            pushNotification(`Có audio mới/cập nhật (${data.languageCode || "N/A"}) cho POI #${data.poiId || "?"}`);
        });

        connection.on("AudioDeleted", (audioId, poiId) => {
            console.log("[SignalR] Audio Deleted:", audioId, poiId);
            showNotification(`Audio bị xóa (ID: ${audioId})`, "warning");
            pushNotification(`Audio bị xóa (ID: ${audioId}) của POI #${poiId || "?"}`);
        });

        connection.on("OwnerRegistrationSubmitted", (data) => {
            console.log("[SignalR] Owner Registration Submitted:", data);
            const shop = data?.shopName || "N/A";
            const email = data?.email || "N/A";
            showNotification(`Đăng ký Owner mới: ${shop}`, "success");
            pushNotification(`Có Owner mới đăng ký: ${shop} (${email})`);
            if (window.location.pathname.toLowerCase().includes("/adminregistrations")) {
                location.reload();
            }
        });

        connection.on("PoiRegistrationSubmitted", (data) => {
            console.log("[SignalR] POI Registration Submitted:", data);
            const poiName = data?.name || "N/A";
            const reqType = data?.requestType || "create";
            showNotification(`Yêu cầu POI mới: ${poiName}`, "info");
            pushNotification(`Có yêu cầu POI (${reqType}) từ Owner: ${poiName}`);
            if (window.location.pathname.toLowerCase().includes("/adminpoiregistrations")) {
                location.reload();
            }
        });

        connection.on("TraceLogged", (trace) => {
            console.log("[SignalR] Trace Logged:", trace);
            if (window.location.pathname.toLowerCase().includes("/analyticsadmin")
                || window.location.pathname.toLowerCase().includes("/tracelogadmin")) {
                window.dispatchEvent(new CustomEvent("vk:trace-logged", { detail: trace }));
            }
        });

        connection.on("RequestFullPoiSync", () => {
            if (window.location.pathname.includes("/PoiAdmin")
                || window.location.pathname.includes("/AdminMap")) {
                location.reload();
            }
        });

        connection.start().catch(err => console.error("[SignalR] Connection error:", err));

        loadNotifications();
        renderNotifications();
        setupNotificationUiEvents();

        // Helper functions
        function showNotification(message, type = "info") {
            const alertClass = `alert alert-${type === "success" ? "success" : type === "warning" ? "warning" : type === "info" ? "info" : "danger"}`;
            const alertHtml = `<div class="${alertClass} alert-dismissible fade show" role="alert" style="position:fixed; top:20px; right:20px; z-index:9999; min-width:300px;">
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
            document.body.insertAdjacentHTML("beforeend", alertHtml);
            setTimeout(() => {
                const alerts = document.querySelectorAll(".alert");
                alerts.forEach(a => a.remove());
            }, 5000);
        }

        function updatePoiInTable(poiId, poiData) {
            const row = document.querySelector(`tr[data-poi-id="${poiId}"]`);
            if (row) {
                row.innerHTML = generatePoiRow(poiData);
            }
        }

        function removePoiFromTable(poiId) {
            const row = document.querySelector(`tr[data-poi-id="${poiId}"]`);
            if (row) {
                row.style.opacity = "0.5";
                setTimeout(() => row.remove(), 200);
            }
        }

        function generatePoiRow(poi) {
            return `<td>${poi.id}</td><td>${poi.name}</td><td>${poi.category || "N/A"}</td><td>${poi.latitude.toFixed(4)}, ${poi.longitude.toFixed(4)}</td><td>${poi.isPublished ? "✓" : "✗"}</td>`;
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>