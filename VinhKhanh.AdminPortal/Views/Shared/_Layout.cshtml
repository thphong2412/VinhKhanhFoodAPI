@{
    var title = ViewData["Title"] as string ?? "Vinh Khanh Admin";
    string currentPath = Context.Request.Path.ToString().ToLower();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f7f7fa; }
        .navbar { background: linear-gradient(90deg, #e67e22 0%, #f1c40f 100%); }
        .navbar-brand, .nav-link, .navbar-nav .nav-link.active { color: #fff !important; font-weight: bold; }
        .sidebar {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 8px #e67e22a0;
            padding: 24px 12px;
            min-height: 90vh;
        }
        .sidebar .nav-link {
            color: #e67e22 !important;
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 6px;
            border-left: 4px solid transparent;
            background: #fff7ec;
            transition: background 0.2s, color 0.2s, border 0.2s;
        }
        .sidebar .nav-link.active, .sidebar .nav-link[aria-current="page"] {
            background: #ffe5c2;
            color: #d35400 !important;
            border-left: 4px solid #e67e22;
        }
        .sidebar .nav-link:hover {
            background: #ffe5c2;
            color: #d35400 !important;
        }
        .main-content { padding: 32px 16px; }
        .table thead { background: #fbeee0; }
        .table-striped > tbody > tr:nth-of-type(odd) { background: #fff9f2; }
        .btn-primary { background: #e67e22; border: none; }
        .btn-info { background: #27ae60; border: none; }
        .btn-danger { background: #e74c3c; border: none; }
        .badge { background: #e67e22; }
        h1, h2, h3, h4 { color: #e67e22; }
    </style>
    @RenderSection("Head", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Vinh Khanh Admin</a>
            <div class="d-flex ms-auto">
                <form method="post" action="/Account/Logout">
                    <button type="submit" class="btn btn-outline-light ms-2">Đăng xuất</button>
                </form>
            </div>
        </div>
    </nav>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 sidebar">
                <nav class="nav flex-column">
                    <a class="nav-link @(currentPath.StartsWith("/poiadmin") ? "active" : "")" href="/PoiAdmin">Quản lý POI</a>
                    <a class="nav-link @(currentPath.StartsWith("/owneradmin") ? "active" : "")" href="/OwnerAdmin">Quản lý tài khoản Owner</a>
                    <a class="nav-link @(currentPath.StartsWith("/adminpoiregistrations") ? "active" : "")" href="/AdminPoiRegistrations/Pending">Chờ duyệt POI của Owner</a>
                    <a class="nav-link @(currentPath.StartsWith("/tracelogadmin") ? "active" : "")" href="/TraceLogAdmin">Lịch sử sử dụng</a>
                    <a class="nav-link @(currentPath.StartsWith("/analyticsadmin") ? "active" : "")" href="/AnalyticsAdmin">Analytics</a>
                    <a class="nav-link @(currentPath.StartsWith("/touradmin") ? "active" : "")" href="/TourAdmin">Quản lý tour</a>
                </nav>
            </div>
            <div class="col-md-10 main-content">
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>