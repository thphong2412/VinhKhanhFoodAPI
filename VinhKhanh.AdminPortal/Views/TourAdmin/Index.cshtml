@model List<VinhKhanh.Shared.TourModel>
@{
    ViewData["Title"] = "Quản lý tour";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="text-warning"><i class="bi bi-map"></i> Quản lý tour</h2>
        </div>
        <div class="col-auto">
            <a href="@Url.Action("Create")" class="btn btn-warning">
                <i class="bi bi-plus-circle"></i> Thêm tour mới
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            @if (Model?.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Tên tour</th>
                                <th>Số POI</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var tour in Model)
                        {
                            <tr>
                                <td><span class="badge bg-primary">@tour.Id</span></td>
                                <td><strong>@tour.Name</strong></td>
                                <td>
                                    @if (tour.PoiIds?.Count > 0)
                                    {
                                        <span class="badge bg-info">@tour.PoiIds.Count POI</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">0 POI</span>
                                    }
                                </td>
                                <td>
                                    @if (tour.IsPublished)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Đã xuất bản</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning"><i class="bi bi-clock"></i> Chưa xuất bản</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = tour.Id })" class="btn btn-sm btn-info" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = tour.Id })" class="btn btn-sm btn-warning" title="Chỉnh sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal@tour.Id" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                    <!-- Delete Modal -->
                                    <div class="modal fade" id="deleteModal@tour.Id" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header bg-danger text-white">
                                                    <h5 class="modal-title">Xác nhận xóa</h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>Bạn có chắc chắn muốn xóa tour "<strong>@tour.Name</strong>" không?</p>
                                                    <p class="text-danger"><strong>⚠️ Hành động này không thể hoàn tác.</strong></p>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                    <form method="post" action="@Url.Action("Delete", new { id = tour.Id })" style="display:inline;">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-danger">Xóa</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Chưa có tour nào. <a href="@Url.Action("Create")" class="alert-link">Tạo tour mới</a>
                </div>
            }
        </div>
    </div>
</div>
