@model VinhKhanh.Shared.TourModel
@{
    ViewData["Title"] = "Thêm tour mới";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Thêm tour mới</h2>
        <a href="@Url.Action("Index")" class="btn btn-secondary">← Quay lại</a>
    </div>

    @if (ViewData.ModelState.IsValid == false)
    {
        <div class="alert alert-danger">
            @Html.ValidationSummary(true, "", new { @class = "mb-0" })
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Thông tin tour</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label" for="Name">Tên tour <span class="text-danger">*</span></label>
                            <input class="form-control" id="Name" name="Name" value="@Model?.Name" required placeholder="Nhập tên tour" />
                            <span class="text-danger">@Html.ValidationMessage("Name")</span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="Description">Mô tả</label>
                            <textarea class="form-control" id="Description" name="Description" rows="5" placeholder="Nhập mô tả tour">@Model?.Description</textarea>
                            <span class="text-danger">@Html.ValidationMessage("Description")</span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="PoiIdsRaw">Danh sách POI <span class="text-muted">(ID, cách nhau bởi dấu phẩy)</span></label>
                            <input class="form-control" id="PoiIdsRaw" name="PoiIdsRaw" value="@string.Join(",", Model?.PoiIds ?? new List<int>())" placeholder="Ví dụ: 1,2,3,4" />
                            <small class="form-text text-muted d-block mt-2">
                                <i class="bi bi-info-circle"></i> Nhập ID các POI thuộc tour này, cách nhau bởi dấu phẩy. Ví dụ: 1,2,3
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="IsPublished">Trạng thái duyệt</label>
                            <select class="form-select" id="IsPublished" name="IsPublished">
                                @{ var isPub = Model?.IsPublished == true; }
                                @if (isPub)
                                {
                                    <option value="true" selected>Đã duyệt</option>
                                    <option value="false">Chưa duyệt</option>
                                }
                                else
                                {
                                    <option value="true">Đã duyệt</option>
                                    <option value="false" selected>Chưa duyệt</option>
                                }
                            </select>
                            <small class="form-text text-muted d-block mt-2">
                                <i class="bi bi-info-circle"></i> Chỉ tour đã duyệt mới hiển thị trong ứng dụng
                            </small>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" type="submit">
                                <i class="bi bi-check-circle"></i> Tạo tour
                            </button>
                            <a class="btn btn-outline-secondary" href="@Url.Action("Index")">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Hướng dẫn</h5>
                </div>
                <div class="card-body">
                    <h6 class="mb-2">Cách tạo tour:</h6>
                    <ol class="small">
                        <li>Nhập tên tour</li>
                        <li>Thêm mô tả (tùy chọn)</li>
                        <li>Danh sách POI - nhập ID các POI cách nhau bởi dấu phẩy</li>
                        <li>Chọn trạng thái duyệt</li>
                        <li>Nhấn "Tạo tour"</li>
                    </ol>
                    <hr />
                    <p class="small text-muted mb-0">
                        <i class="bi bi-lightbulb"></i> Bạn có thể chỉnh sửa tour sau khi tạo.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
