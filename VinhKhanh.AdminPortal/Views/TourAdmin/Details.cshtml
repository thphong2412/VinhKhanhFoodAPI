@model VinhKhanh.Shared.TourModel
@{
    ViewData["Title"] = "Chi tiết tour";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Chi tiết tour: @Model.Name</h2>
        <a href="@Url.Action("Index")" class="btn btn-secondary">← Quay lại</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Thông tin tour</h5>
                </div>
                <div class="card-body">
                    <p><strong>ID:</strong> <span class="badge bg-primary">@Model.Id</span></p>
                    <p><strong>Tên:</strong> @Model.Name</p>
                    <p><strong>Mô tả:</strong></p>
                    <p>@Html.Raw(Model.Description)</p>
                    <p><strong>Trạng thái:</strong>
                        @if (Model.IsPublished)
                        {
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Đã duyệt</span>
                        }
                        else
                        {
                            <span class="badge bg-warning"><i class="bi bi-clock"></i> Chưa duyệt</span>
                        }
                    </p>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Danh sách POI (@(Model.PoiIds?.Count ?? 0))</h5>
                </div>
                <div class="card-body">
                    @if (Model.PoiIds?.Count > 0)
                    {
                        <div class="list-group">
                        @foreach (var poiId in Model.PoiIds)
                        {
                            <a href="@Url.Action("Details", "PoiAdmin", new { id = poiId })" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>POI #@poiId</span>
                                <span class="badge bg-info">Chi tiết</span>
                            </a>
                        }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Tour này chưa có POI nào. <a href="@Url.Action("Edit", new { id = Model.Id })" class="alert-link">Chỉnh sửa</a> để thêm POI.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h5 class="mb-0">Hành động</h5>
                </div>
                <div class="card-body">
                    <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning w-100 mb-2">
                        <i class="bi bi-pencil"></i> Chỉnh sửa
                    </a>

                    <button type="button" class="btn btn-danger w-100 mb-3" data-bs-toggle="modal" data-bs-target="#deleteModal">
                        <i class="bi bi-trash"></i> Xóa
                    </button>

                    <hr />
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary w-100">
                        ← Quay lại danh sách
                    </a>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Thông tin</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-0">
                        <small>Số lượng POI: <strong>@(Model.PoiIds?.Count ?? 0)</strong></small>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Xác nhận xóa</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa tour "<strong>@Model.Name</strong>" không?</p>
                <p class="text-danger"><strong>⚠️ Hành động này không thể hoàn tác.</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form method="post" action="@Url.Action("Delete", new { id = Model.Id })" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>
