@model List<VinhKhanh.AdminPortal.Models.TraceLogRowDto>
@{
    ViewData["Title"] = "Lịch sử sử dụng (TraceLog)";

    TimeZoneInfo vnTz;
    try
    {
        vnTz = TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time");
    }
    catch
    {
        vnTz = TimeZoneInfo.Local;
    }

    string ToVnFromUtc(DateTime utc, string format = "yyyy-MM-dd HH:mm:ss")
    {
        var u = utc.Kind == DateTimeKind.Utc ? utc : DateTime.SpecifyKind(utc, DateTimeKind.Utc);
        var vn = TimeZoneInfo.ConvertTimeFromUtc(u, vnTz);
        return vn.ToString(format);
    }

    string FormatDuration(double? seconds)
    {
        if (!seconds.HasValue || seconds.Value <= 0) return "-";
        var rounded = Math.Round(seconds.Value, 1, MidpointRounding.AwayFromZero);
        return rounded.ToString("0.0");
    }

    string ExtractEvent(string? extra)
    {
        if (string.IsNullOrWhiteSpace(extra)) return "khác";

        const string marker = "\"event\":\"";
        var start = extra.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        if (start < 0) return "khác";

        start += marker.Length;
        var end = extra.IndexOf('"', start);
        return end > start ? extra[start..end] : "khác";
    }

    string ToDisplayEvent(string eventName) => eventName switch
    {
        "tts_play" => "TTS",
        "audio_play" => "Audio",
        "poi_detail_open" => "Chi tiết",
        "poi_enter" => "Vào POI",
        "qr_scan" => "Quét QR",
        "poi_heartbeat" => "Tuyến di chuyển",
        _ => "Khác"
    };

    string BadgeForEvent(string eventName) => eventName switch
    {
        "tts_play" => "<span class=\"badge bg-primary\">TTS</span>",
        "audio_play" => "<span class=\"badge bg-info text-dark\">Audio</span>",
        "poi_detail_open" => "<span class=\"badge bg-warning text-dark\">Chi tiết</span>",
        "poi_enter" => "<span class=\"badge bg-success\">Vào POI</span>",
        "qr_scan" => "<span class=\"badge bg-dark\">QR</span>",
        "poi_heartbeat" => "<span class=\"badge bg-secondary\">Tuyến di chuyển</span>",
        _ => "<span class=\"badge bg-light text-dark\">Khác</span>"
    };
}

<h1>Lịch sử sử dụng</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-bordered table-striped align-middle">
    <thead>
        <tr>
            <th>Thời gian</th>
            <th>POI</th>
            <th>Device</th>
            <th>Tên POI</th>
            <th>Thời lượng nghe (giây)</th>
            <th>Sự kiện</th>
        </tr>
    </thead>
    <tbody id="traceRows">
    @foreach (var log in Model)
    {
        var eventName = ExtractEvent(log.ExtraJson);
        var displayEvent = ToDisplayEvent(eventName);
        <tr>
            <td>@ToVnFromUtc(log.TimestampUtc)</td>
            <td>@log.PoiId</td>
            <td><span class="badge bg-info text-dark">@log.DeviceId</span></td>
            <td>@(string.IsNullOrWhiteSpace(log.PoiName) ? (log.PoiId > 0 ? $"POI #{log.PoiId}" : "-") : log.PoiName)</td>
            <td>@FormatDuration(log.DurationSeconds)</td>
            <td>@Html.Raw(BadgeForEvent(eventName))</td>
        </tr>
    }
    </tbody>
</table>

@if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
{
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    <nav aria-label="Trace log pagination" class="mt-3">
        <ul class="pagination pagination-sm">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = page - 1 })">&laquo;</a>
            </li>
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                </li>
            }
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = page + 1 })">&raquo;</a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        (function () {
            const traceRows = document.getElementById("traceRows");
            if (!traceRows) return;

            function eventNameFromExtra(extra) {
                if (!extra) return "khác";
                const match = extra.match(/"event":"([^"]+)"/i);
                return match && match[1] ? match[1] : "khác";
            }

            function badgeForEvent(eventName) {
                if (eventName === "tts_play") return '<span class="badge bg-primary">TTS</span>';
                if (eventName === "audio_play") return '<span class="badge bg-info text-dark">Audio</span>';
                if (eventName === "poi_detail_open") return '<span class="badge bg-warning text-dark">Chi tiết</span>';
                if (eventName === "poi_enter") return '<span class="badge bg-success">Vào POI</span>';
                if (eventName === "qr_scan") return '<span class="badge bg-dark">QR</span>';
                if (eventName === "poi_heartbeat") return '<span class="badge bg-secondary">Tuyến di chuyển</span>';
                return '<span class="badge bg-light text-dark">Khác</span>';
            }

            function formatDuration(seconds) {
                if (seconds === null || seconds === undefined || seconds <= 0) return "-";
                const rounded = Math.round(seconds * 10) / 10;
                return rounded.toFixed(1);
            }

            function safeText(v) {
                if (v === null || v === undefined) return "-";
                return String(v)
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;");
            }

            function toLocalStringUtc(value) {
                const d = value ? new Date(value) : new Date();
                if (isNaN(d.getTime())) return "-";
                const pad = n => String(n).padStart(2, "0");
                return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
            }

            function prependRealtimeRow(trace) {
                const extra = trace?.extraJson || "";
                const eventName = eventNameFromExtra(extra);
                const row = document.createElement("tr");
                const poiName = trace?.poiName && String(trace.poiName).trim().length > 0
                    ? String(trace.poiName)
                    : (trace?.poiId > 0 ? `POI #${trace.poiId}` : "-");

                row.innerHTML = `
                    <td>${safeText(toLocalStringUtc(trace?.timestampUtc))}</td>
                    <td>${safeText(trace?.poiId ?? 0)}</td>
                    <td><span class="badge bg-info text-dark">${safeText(trace?.deviceId || "-")}</span></td>
                    <td>${safeText(poiName)}</td>
                    <td>${formatDuration(trace?.durationSeconds)}</td>
                    <td>${badgeForEvent(eventName)}</td>
                `;

                traceRows.prepend(row);

                while (traceRows.rows.length > 200) {
                    traceRows.deleteRow(traceRows.rows.length - 1);
                }
            }

            window.addEventListener("vk:trace-logged", function (e) {
                prependRealtimeRow(e.detail || {});
            });
        })();
    </script>
}
