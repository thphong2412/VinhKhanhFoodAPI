@model VinhKhanh.AdminPortal.Models.OwnerRegistrationDto
@{
    ViewData["Title"] = "Chi tiết đơn đăng ký";
}

<div class="container mt-4">
    <h2>Chi tiết đơn đăng ký</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (Model != null)
    {
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>ID:</strong> @Model.Id</p>
                        <p><strong>User ID:</strong> @Model.UserId</p>
                        <p><strong>Email:</strong> @Model.Email</p>
                        <p><strong>Tên shop:</strong> @Model.ShopName</p>
                        <p><strong>Địa chỉ:</strong> @Model.ShopAddress</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>CCCD (mã hóa):</strong> <code>@Model.CccdEncrypted</code></p>
                        <p><strong>Trạng thái:</strong> <span class="badge bg-warning">@Model.Status</span></p>
                        <p><strong>Ngày đăng ký:</strong> @Model.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        @if (Model.ReviewedAt.HasValue)
                        {
                            <p><strong>Ngày duyệt:</strong> @Model.ReviewedAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                        }
                        @if (!string.IsNullOrEmpty(Model.Notes))
                        {
                            <p><strong>Ghi chú:</strong> @Model.Notes</p>
                        }
                    </div>
                </div>

                @if (Model.Status == "pending")
                {
                    <hr />
                    <h4>Xét duyệt</h4>
                    <form method="post" class="mt-3">
                        <div class="mb-3">
                            <label class="form-label">Ghi chú (nếu cần):</label>
                            <textarea name="notes" class="form-control" rows="3"></textarea>
                        </div>
                        <div>
                            <button type="submit" formaction="@Url.Action("Approve", new { id = Model.Id })" class="btn btn-success">✓ Phê duyệt</button>
                            <button type="submit" formaction="@Url.Action("Reject", new { id = Model.Id })" class="btn btn-danger">✗ Từ chối</button>
                            <a href="@Url.Action("Pending")" class="btn btn-secondary">Quay lại</a>
                        </div>
                    </form>
                }
                else
                {
                    <div class="alert alert-info mt-3">
                        Đơn đăng ký này đã được xử lý (Trạng thái: @Model.Status)
                    </div>
                    <a href="@Url.Action("Pending")" class="btn btn-secondary">Quay lại</a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">Không tìm thấy đơn đăng ký</div>
    }
</div>
