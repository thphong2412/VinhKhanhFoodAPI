@model VinhKhanh.AdminPortal.Controllers.AdminRouteMapViewModel
@{
    ViewData["Title"] = "Bản đồ tuyến di chuyển";
    var pois = Model?.Pois ?? new List<VinhKhanh.AdminPortal.Models.AdminPoiOverviewDto>();
    var routes = Model?.Routes ?? new List<VinhKhanh.AdminPortal.Models.AnonymousUserRouteDto>();
}

@section Head {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <style>
        #routeMap {
            height: 74vh;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 2px 10px rgba(0,0,0,.08);
        }

        .route-toolbar {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .route-meta {
            color: #6b7280;
            font-size: .9rem;
        }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">🧭 Tuyến di chuyển ẩn danh</h2>
    <span class="badge bg-dark">Users: <span id="routeUserCount">@routes.Count</span></span>
</div>

<div class="route-toolbar">
    <select id="hoursFilter" class="form-select" style="max-width:210px;">
        <option value="6" selected="@(Model?.Hours == 6)">6 giờ gần đây</option>
        <option value="12" selected="@(Model?.Hours == 12)">12 giờ gần đây</option>
        <option value="24" selected="@(Model?.Hours == 24)">24 giờ gần đây</option>
        <option value="48" selected="@(Model?.Hours == 48)">48 giờ gần đây</option>
        <option value="72" selected="@(Model?.Hours == 72)">72 giờ gần đây</option>
        <option value="168" selected="@(Model?.Hours == 168)">7 ngày</option>
    </select>
    <button class="btn btn-outline-secondary" type="button" id="btnReloadRouteMap">Làm mới</button>
    <button class="btn btn-outline-primary" type="button" id="btnOpenPoiCenterOnGoogle">Mở tâm POI</button>
    <span class="route-meta">Dữ liệu ẩn danh theo thiết bị (không lưu tên/sđt/email).</span>
</div>

<div id="routeMap"></div>

<div class="mt-3 card">
    <div class="card-header bg-light"><strong>Tóm tắt tuyến theo user ẩn danh</strong></div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-bordered align-middle mb-0" id="routeSummaryTable">
                <thead class="table-light">
                    <tr>
                        <th>User ẩn danh</th>
                        <th>Điểm route</th>
                        <th>Lần cuối</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script>
        const initialData = {
            pois: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(pois.Select(p => new {
                p.Id,
                p.Name,
                p.Latitude,
                p.Longitude,
                p.IsPublished,
                p.Category
            }))),
            routes: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(routes)),
            hours: @(Model?.Hours ?? 24)
        };

        const defaultCenter = [10.7731577, 106.582758];
        const map = L.map('routeMap').setView(defaultCenter, 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        const poiLayer = L.layerGroup().addTo(map);
        const routeLayer = L.layerGroup().addTo(map);
        const summaryBody = document.querySelector('#routeSummaryTable tbody');

        function normalizePoi(raw) {
            return {
                id: raw?.id ?? raw?.Id,
                name: raw?.name ?? raw?.Name,
                latitude: raw?.latitude ?? raw?.Latitude,
                longitude: raw?.longitude ?? raw?.Longitude,
                isPublished: raw?.isPublished ?? raw?.IsPublished,
                category: raw?.category ?? raw?.Category
            };
        }

        function normalizeRoute(raw) {
            const points = (raw?.points ?? raw?.Points ?? []).map(p => ({
                latitude: p?.latitude ?? p?.Latitude,
                longitude: p?.longitude ?? p?.Longitude,
                timestampUtc: p?.timestampUtc ?? p?.TimestampUtc,
                poiId: p?.poiId ?? p?.PoiId
            })).filter(p => Number.isFinite(p.latitude) && Number.isFinite(p.longitude));

            const orderedPoints = points.sort((a, b) => new Date(a.timestampUtc).getTime() - new Date(b.timestampUtc).getTime());

            const filteredPoints = filterRoutePoints(orderedPoints);

            return {
                deviceId: raw?.deviceId ?? raw?.DeviceId,
                lastSeenUtc: raw?.lastSeenUtc ?? raw?.LastSeenUtc,
                totalPoints: raw?.totalPoints ?? raw?.TotalPoints ?? filteredPoints.length,
                points: filteredPoints
            };
        }

        function maskDeviceId(value) {
            if (!value) return 'unknown';
            const raw = String(value).trim();
            if (raw.length <= 8) return raw;
            return raw.substring(0, 4) + '...' + raw.substring(raw.length - 4);
        }

        function markerColor(isPublished) {
            return isPublished ? '#0d6efd' : '#f59e0b';
        }

        function routeColor(index) {
            const palette = ['#ef4444', '#3b82f6', '#10b981', '#8b5cf6', '#f97316', '#14b8a6', '#ec4899', '#6366f1'];
            return palette[index % palette.length];
        }

        function formatTime(raw) {
            if (!raw) return '-';
            const d = new Date(raw);
            if (Number.isNaN(d.getTime())) return '-';
            return d.toLocaleString('vi-VN');
        }

        function haversineMeters(lat1, lon1, lat2, lon2) {
            const toRad = (v) => v * Math.PI / 180;
            const dLat = toRad(lat2 - lat1);
            const dLon = toRad(lon2 - lon1);
            const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
                Math.sin(dLon / 2) * Math.sin(dLon / 2);
            return 6371000 * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a)));
        }

        function filterRoutePoints(points) {
            if (!points.length) return [];
            const filtered = [points[0]];
            let last = points[0];
            const minMoveMeters = 8;
            const maxJumpMeters = 250;
            const maxJumpSeconds = 60;

            for (let i = 1; i < points.length; i++) {
                const current = points[i];
                const distance = haversineMeters(last.latitude, last.longitude, current.latitude, current.longitude);
                const dt = Math.abs(new Date(current.timestampUtc).getTime() - new Date(last.timestampUtc).getTime()) / 1000;

                if (distance < minMoveMeters) {
                    continue;
                }

                if (distance > maxJumpMeters && dt < maxJumpSeconds) {
                    continue;
                }

                filtered.push(current);
                last = current;
            }

            return filtered;
        }

        function computePoiCenter(pois) {
            const valid = (pois || []).map(normalizePoi).filter(p => Number.isFinite(p.latitude) && Number.isFinite(p.longitude));
            if (!valid.length) return null;

            const sum = valid.reduce((acc, p) => {
                acc.lat += p.latitude;
                acc.lng += p.longitude;
                return acc;
            }, { lat: 0, lng: 0 });

            return [sum.lat / valid.length, sum.lng / valid.length];
        }

        function renderRouteSummary(routes) {
            if (!summaryBody) return;
            if (!routes.length) {
                summaryBody.innerHTML = '<tr><td colspan="3" class="text-center text-muted">Chưa có tuyến di chuyển</td></tr>';
                return;
            }

            summaryBody.innerHTML = routes.map(r => {
                return `<tr>
                    <td><code>${maskDeviceId(r.deviceId)}</code></td>
                    <td>${r.totalPoints || r.points.length}</td>
                    <td>${formatTime(r.lastSeenUtc)}</td>
                </tr>`;
            }).join('');
        }

        function renderMap(payload) {
            const pois = (payload?.pois || []).map(normalizePoi).filter(p => Number.isFinite(p.latitude) && Number.isFinite(p.longitude));
            const routes = (payload?.routes || []).map(normalizeRoute).filter(r => r.points.length >= 1);

            poiLayer.clearLayers();
            routeLayer.clearLayers();

            const poiBounds = [];
            pois.forEach(p => {
                const latlng = [p.latitude, p.longitude];
                poiBounds.push(latlng);
                const marker = L.circleMarker(latlng, {
                    radius: 6,
                    color: markerColor(p.isPublished),
                    fillColor: markerColor(p.isPublished),
                    fillOpacity: 0.85,
                    weight: 2
                }).bindPopup(`<strong>${p.name || '(Không tên)'}</strong><br/>#${p.id || 0}<br/>${p.category || ''}`);
                marker.addTo(poiLayer);
            });

            const routeBounds = [];
            routes.forEach((r, idx) => {
                const color = routeColor(idx);
                const polylinePoints = r.points.map(p => [p.latitude, p.longitude]);
                if (!polylinePoints.length) return;
                polylinePoints.forEach(pt => routeBounds.push(pt));

                const first = polylinePoints[0];
                const last = polylinePoints[polylinePoints.length - 1];

                if (polylinePoints.length >= 2) {
                    const routeLine = L.polyline(polylinePoints, {
                        color,
                        weight: 4,
                        opacity: 0.8
                    });

                    routeLine.bindPopup(`<strong>User:</strong> ${maskDeviceId(r.deviceId)}<br/><strong>Points:</strong> ${r.totalPoints}<br/><strong>Last:</strong> ${formatTime(r.lastSeenUtc)}`);
                    routeLine.addTo(routeLayer);

                    const heatPoints = polylinePoints.map(pt => [...pt, 0.6]);
                    if (typeof L.heatLayer === 'function') {
                        L.heatLayer(heatPoints, { radius: 18, blur: 14, maxZoom: 17, gradient: { 0.4: '#93c5fd', 0.7: '#60a5fa', 1.0: '#1d4ed8' } }).addTo(routeLayer);
                    }

                    L.circleMarker(first, { radius: 4, color, fillColor: color, fillOpacity: 0.9, weight: 1 }).bindTooltip('Start').addTo(routeLayer);
                    L.circleMarker(last, { radius: 5, color, fillColor: color, fillOpacity: 1, weight: 2 }).bindTooltip('Now').addTo(routeLayer);
                    return;
                }

                L.circleMarker(first, { radius: 5, color, fillColor: color, fillOpacity: 0.95, weight: 2 })
                    .bindPopup(`<strong>User:</strong> ${maskDeviceId(r.deviceId)}<br/><strong>Points:</strong> ${r.totalPoints}<br/><strong>Last:</strong> ${formatTime(r.lastSeenUtc)}`)
                    .bindTooltip('Now')
                    .addTo(routeLayer);
            });

            document.getElementById('routeUserCount').textContent = routes.length;
            renderRouteSummary(routes);

            const preferredBounds = poiBounds.length ? poiBounds : routeBounds;
            if (preferredBounds.length === 1) {
                map.setView(preferredBounds[0], 16);
            } else if (preferredBounds.length > 1) {
                map.fitBounds(preferredBounds, { padding: [30, 30] });
            } else {
                map.setView(defaultCenter, 13);
            }
        }

        async function reloadRouteData() {
            try {
                const hours = Number(document.getElementById('hoursFilter')?.value || initialData.hours || 24);
                const response = await fetch(`/AdminRouteMap/Data?hours=${hours}`, { cache: 'no-store' });
                if (!response.ok) return;
                const data = await response.json();
                window.__routeMapPayload = {
                    pois: data?.pois ?? data?.Pois ?? [],
                    routes: data?.routes ?? data?.Routes ?? [],
                    hours
                };
                renderMap(window.__routeMapPayload);
            } catch (e) {
                console.error('Reload route map failed', e);
            }
        }

        document.getElementById('btnReloadRouteMap')?.addEventListener('click', reloadRouteData);
        document.getElementById('hoursFilter')?.addEventListener('change', reloadRouteData);
        document.getElementById('btnOpenPoiCenterOnGoogle')?.addEventListener('click', () => {
            const center = computePoiCenter(window.__routeMapPayload?.pois || []);
            if (!center) return;
            const [lat, lng] = center;
            const url = `https://www.google.com/maps?q=${encodeURIComponent(lat + ',' + lng)}`;
            window.open(url, '_blank', 'noopener');
        });

        window.__routeMapPayload = initialData;
        renderMap(window.__routeMapPayload);

        setInterval(reloadRouteData, 20000);

        window.addEventListener('vk:trace-logged', () => {
            reloadRouteData();
        });
    </script>
}
