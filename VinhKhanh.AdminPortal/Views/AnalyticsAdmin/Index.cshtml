@using VinhKhanh.AdminPortal.Models;
@using System.Text.Json;
@{
    ViewData["Title"] = "Analytics";
    var heatmap = ViewData["Heatmap"] as IEnumerable<HeatmapPointDto>;
    var poiOverview = ViewData["PoiOverview"] as IEnumerable<AdminPoiOverviewDto>;
    var googleMapsApiKey = ViewData["GoogleMapsApiKey"] as string ?? string.Empty;
    var topPois = ViewData["TopPois"] as IEnumerable<TopPoiDto>;
    var engagement = ViewData["Engagement"] as IEnumerable<PoiEngagementDto>;
    var activeUsers = ViewData["ActiveUsers"] as IEnumerable<ActiveUserDto>;
    var qrScanCounts = ViewData["QrScanCounts"] as IEnumerable<QrScanCountDto>;
    var topVisitedToday = ViewData["TopVisitedToday"] as IEnumerable<TopVisitedTodayDto>;
    var timeseries = ViewData["Timeseries"] is System.Text.Json.JsonElement ts ? ts : default;
    var appListenMetrics = ViewData["AppListenMetrics"] is System.Text.Json.JsonElement am ? am : default;
    var summary = ViewData["Summary"] as AnalyticsSummaryDto ?? new AnalyticsSummaryDto();
    var activeUsersPage = 1;
    var activeUsersPageSize = 10;
    if (int.TryParse(Context.Request.Query["activeUsersPage"], out var parsedActivePage) && parsedActivePage > 0)
    {
        activeUsersPage = parsedActivePage;
    }
    var hourly = (timeseries.ValueKind == System.Text.Json.JsonValueKind.Object && timeseries.TryGetProperty("Hourly", out var h)) ? h : default;
    var daily = (timeseries.ValueKind == System.Text.Json.JsonValueKind.Object && timeseries.TryGetProperty("Daily", out var d)) ? d : default;
    var appTtsPlay = (appListenMetrics.ValueKind == System.Text.Json.JsonValueKind.Object && appListenMetrics.TryGetProperty("app_tts_play", out var a1)) ? a1.GetInt32() : 0;
    var appAudioPlay = (appListenMetrics.ValueKind == System.Text.Json.JsonValueKind.Object && appListenMetrics.TryGetProperty("app_audio_play", out var a2)) ? a2.GetInt32() : 0;
    var appTotalListen = (appListenMetrics.ValueKind == System.Text.Json.JsonValueKind.Object && appListenMetrics.TryGetProperty("app_total_listen", out var a3)) ? a3.GetInt32() : (appTtsPlay + appAudioPlay);
    var totalQrScan = qrScanCounts?.Sum(x => x.Count) ?? 0;

    TimeZoneInfo vnTz;
    try
    {
        vnTz = TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time");
    }
    catch
    {
        vnTz = TimeZoneInfo.Local;
    }

    string FormatUtcStringToVn(string? raw, string format = "yyyy-MM-dd HH:mm:ss")
    {
        if (string.IsNullOrWhiteSpace(raw)) return "-";
        if (!DateTime.TryParse(raw, null, System.Globalization.DateTimeStyles.AssumeUniversal | System.Globalization.DateTimeStyles.AdjustToUniversal, out var utc))
        {
            return raw;
        }

        var vn = TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(utc, DateTimeKind.Utc), vnTz);
        return vn.ToString(format);
    }

    string ToVnFromUtc(DateTime utc, string format = "yyyy-MM-dd HH:mm:ss")
    {
        var u = utc.Kind == DateTimeKind.Utc ? utc : DateTime.SpecifyKind(utc, DateTimeKind.Utc);
        var vn = TimeZoneInfo.ConvertTimeFromUtc(u, vnTz);
        return vn.ToString(format);
    }
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="text-warning"><i class="bi bi-graph-up"></i> Phân tích dữ liệu</h2>
        </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-primary h-100">
                <div class="card-body">
                    <div class="text-muted small">Tổng lượt nghe trong app</div>
                    <div class="h3 fw-bold text-primary mb-0">@appTotalListen</div>
                    <div class="small text-muted">TTS: @appTtsPlay · Audio: @appAudioPlay</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-success h-100">
                <div class="card-body">
                    <div class="text-muted small">QR Scan</div>
                    <div class="h3 fw-bold text-success mb-0">@totalQrScan</div>
                </div>
            </div>
        </div>
        @* ============================================================ *@
        @* [FEATURE: User đang online (realtime)]                         *@
        @* - Source: ViewData["Summary"] (AnalyticsSummaryDto)             *@
        @* - Lấy từ: AnalyticsAdminController.Index() →                   *@
        @*           GET api/analytics/summary                            *@
        @* - Logic tính online: VinhKhanh.API/Controllers/                 *@
        @*           AnalyticsController.GetSummary()                     *@
        @* - Auto refresh: setInterval ~20s + SignalR "vk:trace-logged"    *@
        @* ============================================================ *@
        <div class="col-md-2">
            <div class="card border-info h-100">
                <div class="card-body">
                    <div class="text-muted small">User đang online</div>
                    <div class="h3 fw-bold text-info mb-0" id="kpiOnlineUsers">@summary.OnlineUsers</div>
                    <div class="small text-muted">Realtime</div>
                </div>
            </div>
        </div>
        @* [FEATURE: Khách hôm nay] — đếm distinct deviceId trong 24h hôm nay *@
        <div class="col-md-2">
            <div class="card border-secondary h-100">
                <div class="card-body">
                    <div class="text-muted small">Khách hôm nay</div>
                    <div class="h3 fw-bold text-secondary mb-0" id="kpiVisitorsToday">@summary.VisitorsToday</div>
                    <div class="small text-muted">24h hiện tại</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">QR scan theo POI</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>POI ID</th>
                        <th>Tên POI</th>
                        <th>Lượt quét QR</th>
                    </tr>
                </thead>
                <tbody>
                @if (qrScanCounts?.Any() == true)
                {
                    foreach (var c in qrScanCounts)
                    {
                        <tr>
                            <td>@c.PoiId</td>
                            <td>@(string.IsNullOrWhiteSpace(c.PoiName) ? "-" : c.PoiName)</td>
                            <td>@c.Count</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="3" class="text-center text-muted">Chưa có dữ liệu QR</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>


    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Top POIs Table -->
    <div class="card mb-4">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0"><i class="bi bi-star"></i> Top POIs được nghe nhiều nhất</h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>POI ID</th>
                        <th>Tên POI</th>
                        <th>Chủ quán</th>
                        <th>Lượt nghe</th>
                        <th>Xem chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                @if (topPois?.Any() == true)
                {
                    foreach (var item in topPois)
                    {
                        <tr>
                            <td><span class="badge bg-primary">@item.PoiId</span></td>
                            <td>@(string.IsNullOrWhiteSpace(item.PoiName) ? "-" : item.PoiName)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.OwnerName) ? "-" : item.OwnerName)</td>
                            <td><span class="fw-bold text-success fs-5">@item.Count</span></td>
                            <td>
                                <a class="btn btn-sm btn-info" href="/PoiAdmin/Details/@item.PoiId">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted">Chưa có dữ liệu</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-geo"></i> Top địa điểm được khách ghé hôm nay (GPS)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>POI ID</th>
                            <th>Tên địa điểm</th>
                            <th>Khách ghé hôm nay</th>
                            <th>GPS đang ở đó</th>
                            <th>Thời gian gần nhất (VN)</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (topVisitedToday?.Any() == true)
                    {
                        foreach (var v in topVisitedToday)
                        {
                            var isInside = v.CurrentlyInside > 0;
                            <tr>
                                <td><span class="badge bg-primary">@v.PoiId</span></td>
                                <td>@(string.IsNullOrWhiteSpace(v.PoiName) ? $"POI #{v.PoiId}" : v.PoiName)</td>
                                <td><span class="fw-bold text-success">@v.VisitorsToday</span></td>
                                <td><span class="badge @(isInside ? "bg-success" : "bg-secondary")">@v.CurrentlyInside</span></td>
                                <td>@(v.LastVisitUtc == default ? "-" : ToVnFromUtc(v.LastVisitUtc))</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center text-muted">Hôm nay chưa có dữ liệu ghé POI theo GPS</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-headphones"></i> Engagement theo POI</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>POI</th>
                            <th>Tổng lượt nghe</th>
                            <th>TTS</th>
                            <th>Audio MP3</th>
                            <th>Mở chi tiết</th>
                            <th>Users</th>
                            <th>Thiết bị</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (engagement?.Any() == true)
                    {
                        foreach (var e in engagement)
                        {
                            <tr>
                                <td>
                                    <strong>@(string.IsNullOrWhiteSpace(e.PoiName) ? $"POI #{e.PoiId}" : e.PoiName)</strong>
                                    <br /><small class="text-muted">#@e.PoiId</small>
                                </td>
                                <td><span class="badge bg-success">@e.TotalListens</span></td>
                                <td><span class="badge bg-primary">@e.TtsPlays</span></td>
                                <td><span class="badge bg-info text-dark">@e.AudioPlays</span></td>
                                <td><span class="badge bg-warning text-dark">@e.DetailOpens</span></td>
                                <td><span class="badge bg-secondary">@e.UniqueUsers</span></td>
                                <td>
                                    @if (e.Users?.Any() == true)
                                    {
                                        var shortDevices = e.Users
                                            .Where(x => !string.IsNullOrWhiteSpace(x))
                                            .Select(x => x.Split('|', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                                            .Select(parts => parts.Length >= 3
                                                ? $"{parts[0]} {parts[2]}"
                                                : (parts.Length >= 1 ? parts[0] : "Unknown"))
                                            .Distinct(StringComparer.OrdinalIgnoreCase)
                                            .Take(5)
                                            .ToList();

                                        <small>@(shortDevices.Any() ? string.Join(", ", shortDevices) : "-")</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center text-muted">Chưa có dữ liệu engagement</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-person-lines-fill"></i> Users hoạt động gần đây</h5>
            <small class="text-light">Auto refresh mỗi 20 giây · 10 dòng/trang</small>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-bordered align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Device/User</th>
                            <th>Total events</th>
                            <th>Last seen (VN, GMT+7)</th>
                            <th>POIs tương tác</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (activeUsers?.Any() == true)
                    {
                        var activeList = activeUsers.ToList();
                        var totalActivePages = Math.Max(1, (int)Math.Ceiling(activeList.Count / (double)activeUsersPageSize));
                        activeUsersPage = Math.Min(activeUsersPage, totalActivePages);
                        foreach (var u in activeList.Skip((activeUsersPage - 1) * activeUsersPageSize).Take(activeUsersPageSize))
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(u.DeviceModel) || !string.IsNullOrWhiteSpace(u.Platform))
                                    {
                                        <div><strong>@(string.IsNullOrWhiteSpace(u.DeviceModel) ? "Unknown device" : u.DeviceModel)</strong></div>
                                        <small class="text-muted">@(string.IsNullOrWhiteSpace(u.Platform) ? "Unknown platform" : u.Platform) @(string.IsNullOrWhiteSpace(u.DeviceVersion) ? string.Empty : $"· {u.DeviceVersion}")</small>
                                        <div><code>@u.DeviceId</code></div>
                                    }
                                    else
                                    {
                                        <code>@u.DeviceId</code>
                                    }
                                </td>
                                <td>@u.TotalEvents</td>
                                <td>@ToVnFromUtc(u.LastSeenUtc)</td>
                                <td><small>@(u.PoiIds?.Any() == true ? string.Join(", ", u.PoiIds.Select(x => $"#{x}")) : "-")</small></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center text-muted">Chưa có user hoạt động</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
        @if (activeUsers?.Any() == true)
        {
            var totalActivePages = Math.Max(1, (int)Math.Ceiling(activeUsers.Count() / (double)activeUsersPageSize));
            if (totalActivePages > 1)
            {
                <div class="card-footer bg-white">
                    <nav aria-label="Active users pagination">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(activeUsersPage <= 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { activeUsersPage = activeUsersPage - 1 })">&laquo;</a>
                            </li>
                            @for (var i = 1; i <= totalActivePages; i++)
                            {
                                <li class="page-item @(i == activeUsersPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { activeUsersPage = i })">@i</a>
                                </li>
                            }
                            <li class="page-item @(activeUsersPage >= totalActivePages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { activeUsersPage = activeUsersPage + 1 })">&raquo;</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>

    <!-- Heatmap -->
    <div class="card mb-4">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Bản đồ nhiệt - Vị trí người dùng nghe nhiều nhất</h5>
        </div>
        <div class="card-body">
            <div id="heatmap" style="height:500px; border-radius: 8px; border: 1px solid #ddd;"></div>
            <small class="text-muted d-block mt-2">
                <i class="bi bi-info-circle"></i> Các điểm màu cam đậm là nơi người dùng nghe thuyết minh nhiều nhất
            </small>
        </div>
    </div>

    <!-- Average Duration Table -->
    <div class="card">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0"><i class="bi bi-clock"></i> Thời gian nghe trung bình mỗi POI</h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered align-middle" id="avgDurationTable">
                <thead class="table-light">
                    <tr>
                        <th>POI ID</th>
                        <th>Thời gian TB (giây)</th>
                    </tr>
                </thead>
                <tbody>
                @if (topPois?.Any() == true)
                {
                    foreach (var item in topPois)
                    {
                        <tr data-poiid="@item.PoiId">
                            <td><span class="badge bg-primary">@item.PoiId</span></td>
                            <td class="avg-cell"><span class="spinner-border spinner-border-sm" role="status"><span class="visually-hidden">Đang tải...</span></span></td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="2" class="text-center text-muted">Chưa có dữ liệu</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>
    @if (!string.IsNullOrWhiteSpace(googleMapsApiKey))
    {
        <script src="https://maps.googleapis.com/maps/api/js?key=@googleMapsApiKey&libraries=visualization"></script>
    }
    <script>
        const apiBase = (document.getElementById("vk-config")?.dataset?.apiBase || "http://localhost:5291/").replace(/\/$/, "");
        const googleMapsApiKey = '@googleMapsApiKey';

        // Initialize Heatmap
        function initHeatmap() {
            var poiPoints = @Html.Raw(JsonSerializer.Serialize(
                poiOverview
                    ?.Where(p => p != null && p.Latitude >= -90 && p.Latitude <= 90 && p.Longitude >= -180 && p.Longitude <= 180)
                    .Select(p => new object[]
                    {
                        p.Latitude,
                        p.Longitude,
                        p.Name ?? string.Empty,
                        p.OwnerName ?? string.Empty,
                        p.Id
                    })
                    .ToList() ?? new List<object[]>()));

            var points = @Html.Raw(JsonSerializer.Serialize(
                heatmap?.Select(p => new object[] { p.Latitude, p.Longitude }).ToList()
                ?? new List<object[]>()));

            const canUseGoogleHeatmap = !!googleMapsApiKey
                && typeof window.google !== 'undefined'
                && google.maps
                && google.maps.visualization;

            if (canUseGoogleHeatmap) {
                const preferredBounds = poiPoints.length > 0 ? poiPoints : points;
                let center = { lat: 10.762622, lng: 106.660172 };
                if (preferredBounds.length > 0) {
                    const first = preferredBounds[0];
                    center = { lat: first[0], lng: first[1] };
                }

                const gmap = new google.maps.Map(document.getElementById('heatmap'), {
                    center,
                    zoom: 13,
                    mapTypeId: 'roadmap',
                    streetViewControl: false,
                    fullscreenControl: true,
                    mapTypeControl: false
                });

                if (points.length > 0) {
                    const heatData = points.map(p => new google.maps.LatLng(p[0], p[1]));
                    new google.maps.visualization.HeatmapLayer({
                        data: heatData,
                        radius: 32,
                        opacity: 0.78
                    }).setMap(gmap);
                }

                if (preferredBounds.length > 1) {
                    const bounds = new google.maps.LatLngBounds();
                    preferredBounds.forEach(p => bounds.extend({ lat: p[0], lng: p[1] }));
                    gmap.fitBounds(bounds, 48);
                } else if (preferredBounds.length === 1) {
                    gmap.setZoom(16);
                }

                return;
            }

            var map = L.map('heatmap').setView([10.762622, 106.660172], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            if (points.length > 0) {
                L.heatLayer(points, {
                    radius: 25,
                    blur: 18,
                    maxZoom: 17,
                    gradient: { 0.4: '#ffe082', 0.7: '#ffb300', 1.0: '#e67e22' }
                }).addTo(map);
            }

            var preferredBounds = poiPoints.length > 0 ? poiPoints : points;
            if (preferredBounds.length === 1) {
                map.setView(preferredBounds[0], 16);
            } else if (preferredBounds.length > 1) {
                map.fitBounds(preferredBounds, { padding: [30, 30] });
            }
        }

        // Load avg duration for each POI
        document.addEventListener('DOMContentLoaded', function() {
            let refreshTimer = null;
            const scheduleRealtimeRefresh = function(delayMs) {
                if (refreshTimer) {
                    clearTimeout(refreshTimer);
                }

                refreshTimer = setTimeout(function() {
                    window.location.reload();
                }, Math.max(250, delayMs || 800));
            };

            document.querySelectorAll('#avgDurationTable tr[data-poiid]').forEach(function(row) {
                var poiId = row.getAttribute('data-poiid');
                fetch(apiBase + '/api/analytics/avg-duration?poiId=' + poiId)
                    .then(r => {
                        if (!r.ok) {
                            throw new Error('HTTP ' + r.status);
                        }
                        return r.json();
                    })
                    .then(d => {
                        var cell = row.querySelector('.avg-cell');
                        var avg = Number(d?.avg ?? 0);
                        cell.textContent = Number.isFinite(avg) ? avg.toFixed(2) + ' giây' : '0.00 giây';
                    })
                    .catch(e => {
                        var cell = row.querySelector('.avg-cell');
                        cell.textContent = '0.00 giây';
                        console.error(e);
                    });
            });

            setTimeout(initHeatmap, 300);

            setInterval(function() {
                window.location.reload();
            }, 20000);

            window.addEventListener("vk:trace-logged", function() {
                scheduleRealtimeRefresh(220);
            });

            if (typeof connection !== "undefined" && connection) {
                connection.on("PoiAdded", () => scheduleRealtimeRefresh(500));
                connection.on("PoiUpdated", () => scheduleRealtimeRefresh(500));
                connection.on("PoiDeleted", () => scheduleRealtimeRefresh(500));
                connection.on("ContentCreated", () => scheduleRealtimeRefresh(700));
                connection.on("ContentUpdated", () => scheduleRealtimeRefresh(700));
                connection.on("ContentDeleted", () => scheduleRealtimeRefresh(700));
                connection.on("AudioUploaded", () => scheduleRealtimeRefresh(700));
                connection.on("AudioDeleted", (_audioId, _poiId) => scheduleRealtimeRefresh(700));
                connection.on("RequestFullPoiSync", () => scheduleRealtimeRefresh(400));
            }
        });
    </script>
}
