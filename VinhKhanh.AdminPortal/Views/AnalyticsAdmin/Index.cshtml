@model List<dynamic>
@{
    ViewData["Title"] = "Analytics";
    var heatmap = ViewData["Heatmap"] as IEnumerable<dynamic>;
    var topPois = ViewData["TopPois"] as IEnumerable<dynamic>;
}

<h1>Phân tích dữ liệu</h1>

<div class="mb-4">
    <h3>Top POIs</h3>
    <table class="table table-bordered table-striped align-middle">
        <thead class="table-warning">
            <tr>
                <th>POI</th>
                <th>Lượt nghe</th>
                <th>Xem chi tiết</th>
            </tr>
        </thead>
        <tbody>
        @if (topPois != null)
        {
            foreach (var item in topPois)
            {
                <tr>
                    <td><span class="badge bg-primary">@item.PoiId</span></td>
                    <td><span class="fw-bold text-success">@item.Count</span></td>
                    <td><a class="btn btn-sm btn-info" href="/PoiAdmin/Details/@item.PoiId">Chi tiết</a></td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="3">No data</td></tr>
        }
        </tbody>
    </table>
</div>

<div class="mb-4">
    <h3>Heatmap vị trí người dùng</h3>
    <div id="heatmap" style="height:400px;width:100%;background:#f8f8f8;border-radius:12px;"></div>
    <div class="form-text">Các điểm màu cam đậm là nơi người dùng nghe thuyết minh nhiều nhất.</div>
</div>

<div class="mb-4">
    <h3>Thời gian nghe trung bình mỗi POI (giây)</h3>
    <table class="table table-bordered align-middle" id="avgDurationTable">
        <thead class="table-warning">
            <tr>
                <th>POI</th>
                <th>Thời gian nghe TB (giây)</th>
            </tr>
        </thead>
        <tbody>
        @if (topPois != null)
        {
            foreach (var item in topPois)
            {
                <tr data-poiid="@item.PoiId">
                    <td><span class="badge bg-primary">@item.PoiId</span></td>
                    <td class="avg-cell">Đang tải...</td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>
    <script>
        function initHeatmap() {
            var map = L.map('heatmap').setView([10.762622, 106.660172], 15);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '© OpenStreetMap'
            }).addTo(map);
            var points = [
                @if (heatmap != null)
                {
                    foreach (var p in heatmap)
                    {
                        <text>[@p.Latitude, @p.Longitude],</text>
                    }
                }
            ];
            if(points.length > 0) {
                L.heatLayer(points, {radius: 25, blur: 18, maxZoom: 17, gradient: {0.4: '#ffe082', 0.7: '#ffb300', 1.0: '#e67e22'}}).addTo(map);
            }
        }
        setTimeout(initHeatmap, 500);

        // Lấy thời gian nghe trung bình cho từng POI
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('#avgDurationTable tr[data-poiid]').forEach(function(row) {
                var poiId = row.getAttribute('data-poiid');
                fetch('/api/analytics/avg-duration?poiId=' + poiId)
                    .then(r => r.json())
                    .then(data => {
                        row.querySelector('.avg-cell').innerText = data.avg ? data.avg.toFixed(1) : '0';
                    })
                    .catch(() => {
                        row.querySelector('.avg-cell').innerText = '0';
                    });
            });
        });
    </script>
}
