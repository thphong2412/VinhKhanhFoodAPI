@model VinhKhanh.Shared.PoiModel
@{
    ViewData["Title"] = "Chi tiết POI";
    var apiBaseUrl = (ViewBag.ApiBaseUrl as string ?? string.Empty).Trim();

    string ResolveImageUrl(string raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        if (Uri.TryCreate(raw, UriKind.Absolute, out _)) return raw;
        if (string.IsNullOrWhiteSpace(apiBaseUrl)) return raw;
        return $"{apiBaseUrl.TrimEnd('/')}/{raw.TrimStart('/')}";
    }
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Chi tiết POI: @Model.Name</h2>
        <a href="@Url.Action("Index")" class="btn btn-secondary">← Quay lại</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Thông tin cơ bản</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p><strong>ID:</strong> @Model.Id</p>
                            <p><strong>Tên:</strong> @Model.Name</p>
                            <p><strong>Danh mục:</strong> <span class="badge bg-info">@Model.Category</span></p>
                            <p><strong>Chủ sở hữu ID:</strong> @(Model.OwnerId?.ToString() ?? "N/A")</p>
                            <p><strong>Tên chủ quán:</strong> @(ViewBag.OwnerName ?? "N/A")</p>
                            <p><strong>Email owner:</strong> @(ViewBag.OwnerEmail ?? "N/A")</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Tọa độ:</strong> (@Model.Latitude, @Model.Longitude)</p>
                            <p><strong>Bán kính:</strong> @Model.Radius m</p>
                            <p><strong>Độ ưu tiên:</strong> @Model.Priority</p>
                            <p><strong>Cooldown (giây):</strong> @Model.CooldownSeconds</p>
                            <p><strong>Duyệt lúc:</strong>
                                @if (ViewBag.ApprovedAtUtc != null)
                                {
                                    @(((DateTime)ViewBag.ApprovedAtUtc).ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss"))
                                }
                                else
                                {
                                    <span>Chưa có thông tin duyệt</span>
                                }
                            </p>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Trạng thái duyệt:</strong> 
                                @if (Model.IsPublished)
                                {
                                    <span class="badge bg-success">Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Chưa duyệt</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Trạng thái lưu trữ:</strong> 
                                @if (Model.IsSaved)
                                {
                                    <span class="badge bg-info">Được người dùng yêu thích</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Chưa được lưu</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Hình ảnh -->
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                var imageUrls = Model.ImageUrl
                    .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Where(x => !string.IsNullOrWhiteSpace(x))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList();

                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Hình ảnh</h5>
                    </div>
                    <div class="card-body text-center">
                        @if (imageUrls.Count <= 1)
                        {
                            <img src="@ResolveImageUrl(imageUrls.FirstOrDefault() ?? string.Empty)" alt="@Model.Name" class="img-fluid" style="max-height: 400px;">
                        }
                        else
                        {
                            var carouselId = $"adminPoiImgCarousel_{Model.Id}";
                            <div id="@carouselId" class="carousel slide" data-bs-ride="carousel">
                                <div class="carousel-inner rounded">
                                    @for (var i = 0; i < imageUrls.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : null)">
                                            <img src="@ResolveImageUrl(imageUrls[i])" class="d-block w-100" alt="@Model.Name" style="max-height: 420px; object-fit: cover;">
                                        </div>
                                    }
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                                    <span class="carousel-control-next-icon"></span>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Liên kết -->
            @if (!string.IsNullOrEmpty(Model.WebsiteUrl) || !string.IsNullOrEmpty(Model.QrCode))
            {
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Liên kết</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.WebsiteUrl))
                        {
                            <p><strong>Website:</strong> <a href="@Model.WebsiteUrl" target="_blank">@Model.WebsiteUrl</a></p>
                        }
                        @if (!string.IsNullOrEmpty(Model.QrCode))
                        {
                            var qrUrl = $"https://quickchart.io/qr?size=360&margin=1&text={Uri.EscapeDataString(Model.QrCode)}";
                            <p><strong>QR Code:</strong></p>
                            <div class="d-flex align-items-center gap-3 flex-wrap">
                                <a href="@qrUrl" target="_blank" class="btn btn-sm btn-outline-primary">Xem QR Code</a>
                                <img src="@qrUrl" alt="QR @Model.Name" style="width:120px;height:120px;border:1px solid #ddd;border-radius:8px;" />
                            </div>
                            <small class="text-muted d-block mt-2">Payload: @Model.QrCode</small>
                        }
                    </div>
                </div>
            }

            <!-- Chi tiết nội dung theo ngôn ngữ -->
            @if (Model.Contents != null && Model.Contents.Count > 0)
            {
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Chi tiết nội dung</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var content in Model.Contents)
                        {
                            <div class="mb-4 pb-4 border-bottom">
                                <h6><strong>Ngôn ngữ:</strong> @(content.LanguageCode?.ToUpper() ?? "N/A")</h6>

                                @if (!string.IsNullOrEmpty(content.Title))
                                {
                                    <p><strong>Tiêu đề:</strong> @content.Title</p>
                                }

                                @if (!string.IsNullOrEmpty(content.Subtitle))
                                {
                                    <p><strong>Tiêu đề phụ:</strong> @content.Subtitle</p>
                                }

                                @if (!string.IsNullOrEmpty(content.Description))
                                {
                                    <p><strong>Mô tả:</strong></p>
                                    <p>@Html.Raw(content.Description)</p>
                                }

                                @if (!string.IsNullOrEmpty(content.Address))
                                {
                                    <p><strong>Địa chỉ:</strong> @content.Address</p>
                                }

                                @if (!string.IsNullOrEmpty(content.PhoneNumber))
                                {
                                    <p><strong>Số điện thoại:</strong> @content.PhoneNumber</p>
                                }

                                @if (!string.IsNullOrEmpty(content.OpeningHours))
                                {
                                    <p><strong>Giờ mở cửa:</strong> @content.OpeningHours</p>
                                }

                                @if (!string.IsNullOrEmpty(content.PriceRange))
                                {
                                    <p><strong>Mức giá:</strong> @content.PriceRange</p>
                                }

                                @if (content.Rating > 0)
                                {
                                    <p><strong>Đánh giá:</strong> ⭐ @content.Rating.ToString("F1")</p>
                                }

                                @if (!string.IsNullOrEmpty(content.AudioUrl))
                                {
                                    <p><strong>Audio:</strong>
                                        <audio controls class="mt-2">
                                            <source src="@content.AudioUrl" type="audio/mpeg">
                                            Trình duyệt của bạn không hỗ trợ audio.
                                        </audio>
                                    </p>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Chi tiết nội dung</h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-warning mb-0">
                            POI này chưa có dữ liệu nội dung theo ngôn ngữ. Vào <strong>Chỉnh sửa</strong> để thêm Tiêu đề/Mô tả/Giá/Giờ mở cửa/Địa chỉ.
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar Hành động -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h5 class="mb-0">Hành động</h5>
                </div>
                <div class="card-body">
                    <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning w-100 mb-2">
                        <i class="bi bi-pencil"></i> Chỉnh sửa
                    </a>

                    <button type="button" class="btn btn-danger w-100" data-bs-toggle="modal" data-bs-target="#deleteModal">
                        <i class="bi bi-trash"></i> Xóa
                    </button>

                    <hr />
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary w-100">
                        ← Quay lại danh sách
                    </a>
                </div>
            </div>

            <!-- Map Preview -->
            <div class="card mt-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Vị trí trên bản đồ</h5>
                </div>
                <div class="card-body">
                    <div id="map" style="height: 300px; border: 1px solid #ddd; border-radius: 5px;"></div>
                    <small class="text-muted mt-2 d-block">Tọa độ: @Model.Latitude, @Model.Longitude</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Xác nhận xóa</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa POI "<strong>@Model.Name</strong>" không?</p>
                <p class="text-danger"><strong>⚠️ Hành động này không thể hoàn tác.</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form method="post" action="@Url.Action("Delete", new { id = Model.Id })" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Leaflet Map Library -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script>
        // Initialize map
        const map = L.map('map').setView([@Model.Latitude, @Model.Longitude], 15);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19
        }).addTo(map);

        // Add marker
        const marker = L.marker([@Model.Latitude, @Model.Longitude]).addTo(map)
            .bindPopup('<b>@Model.Name</b><br>(@Model.Latitude, @Model.Longitude)')
            .openPopup();

        // Draw radius circle
        const circle = L.circle([@Model.Latitude, @Model.Longitude], {
            radius: @Model.Radius,
            color: 'red',
            fill: true,
            fillColor: '#f03',
            fillOpacity: 0.1,
            weight: 2
        }).addTo(map);
    </script>
}
