@model VinhKhanh.Shared.PoiModel

<h1>Thêm POI mới</h1>
<form asp-action="Create" method="post" enctype="multipart/form-data" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="OwnerId" value="@ViewData["OwnerId"]" />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <h3>Thông tin cơ bản</h3>
    <div class="col-md-6">
        <label class="form-label">Tên POI</label>
        <input class="form-control" name="Name" value="@Model?.Name" required />
    </div>
    <div class="col-md-6">
        <label class="form-label">Loại (Category)</label>
        <select class="form-select" name="Category" required>
            <option value="">-- Chọn danh mục --</option>
            <option value="Food" selected="@(Model?.Category == "Food")">Ăn uống (Food)</option>
            <option value="Restaurant" selected="@(Model?.Category == "Restaurant")">Nhà hàng (Restaurant)</option>
            <option value="Attraction" selected="@(Model?.Category == "Attraction")">Điểm du lịch (Attraction)</option>
            <option value="Shopping" selected="@(Model?.Category == "Shopping")">Mua sắm (Shopping)</option>
            <option value="Hotel" selected="@(Model?.Category == "Hotel")">Khách sạn (Hotel)</option>
            <option value="Other" selected="@(Model?.Category == "Other")">Khác (Other)</option>
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Vĩ độ (Latitude)</label>
        <input class="form-control" type="number" step="any" name="Latitude" value="@Model?.Latitude" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Kinh độ (Longitude)</label>
        <input class="form-control" type="number" step="any" name="Longitude" value="@Model?.Longitude" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Bán kính (mét)</label>
        <input class="form-control" type="number" name="Radius" value="@Model?.Radius" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Ưu tiên (Priority)</label>
        <input class="form-control" type="number" name="Priority" value="@(Model?.Priority ?? 0)" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Cooldown (giây)</label>
        <input class="form-control" type="number" name="CooldownSeconds" value="@(Model?.CooldownSeconds ?? 30)" />
    </div>

    <!-- ✅ Multiple Image Upload -->
    <h3 class="mt-4">Hình ảnh (3-4 ảnh)</h3>
    <div class="col-12">
        <label class="form-label">📸 Tải ảnh (chọn nhiều file)</label>
        <input class="form-control" type="file" name="ImageFiles" multiple accept="image/*" />
        <small class="text-muted">Chọn 3-4 ảnh PNG/JPG. App sẽ hiển thị carousel</small>
    </div>

    <!-- ✅ Audio Upload -->
    <h3 class="mt-4">Âm thanh Thuyết minh</h3>
    <div class="col-md-6">
        <label class="form-label">🎵 File MP3 (Tiếng Việt)</label>
        <input class="form-control" type="file" name="AudioFile_VI" accept="audio/mpeg" />
        <small class="text-muted">Upload file .mp3 để hiển thị trong tab Audio của app</small>
    </div>
    <div class="col-md-6">
        <label class="form-label">🎵 File MP3 (English)</label>
        <input class="form-control" type="file" name="AudioFile_EN" accept="audio/mpeg" />
        <small class="text-muted">Tùy chọn: file thuyết minh tiếng Anh</small>
    </div>

    <h3 class="mt-4">Chi tiết</h3>
    <div class="col-md-6">
        <label class="form-label">Tiêu đề (Title)</label>
        <input class="form-control" name="ContentTitle_VI" placeholder="Tên chi tiết" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Phụ đề (Subtitle)</label>
        <input class="form-control" name="ContentSubtitle_VI" placeholder="Mô tả ngắn" />
    </div>
    <div class="col-12">
        <label class="form-label">Mô tả (Description)</label>
        <textarea class="form-control" name="ContentDescription_VI" rows="3" placeholder="Mô tả chi tiết"></textarea>
    </div>
    <div class="col-md-3">
        <label class="form-label">Giá tối thiểu</label>
        <input class="form-control" name="ContentPriceMin_VI" placeholder="Ví dụ: 45.000 VND" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Giá tối đa</label>
        <input class="form-control" name="ContentPriceMax_VI" placeholder="Ví dụ: 100.000 VND" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Đánh giá (Rating)</label>
        <input class="form-control" type="number" step="0.1" name="ContentRating_VI" min="0" max="5" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Giờ mở cửa</label>
        <input class="form-control" name="ContentOpenTime_VI" placeholder="10:00" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Giờ đóng cửa</label>
        <input class="form-control" name="ContentCloseTime_VI" placeholder="22:00" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Số điện thoại (PhoneNumber)</label>
        <input class="form-control" name="ContentPhoneNumber_VI" placeholder="0123456789" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Địa chỉ (Address)</label>
        <input class="form-control" name="ContentAddress_VI" placeholder="Số 123, Đường ABC" />
    </div>

    <div class="col-12">
        <div class="alert alert-info mt-2 mb-0" role="alert">
            <strong>💡 Gợi ý:</strong> Nhập chi tiết tiếng Việt làm gốc. Sau khi tạo POI, vào <strong>Bản dịch</strong> và chọn ngôn ngữ cần dịch rồi bấm <strong>Dịch và lưu ngay</strong>.
        </div>
    </div>

    <div class="col-12">
        <button class="btn btn-primary" type="submit">Tạo POI</button>
        <a class="btn btn-secondary ms-2" href="/PoiAdmin">Quay lại</a>
    </div>
</form>
