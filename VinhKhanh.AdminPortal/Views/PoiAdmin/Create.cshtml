@model VinhKhanh.Shared.PoiModel

<h1>Thêm POI mới</h1>
<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="OwnerId" value="@ViewData["OwnerId"]" />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="col-md-6">
        <label class="form-label">Tên</label>
        <input class="form-control" name="Name" value="@Model?.Name" required />
    </div>
    <div class="col-md-6">
        <label class="form-label">Loại</label>
        <input class="form-control" name="Category" value="@Model?.Category" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Vĩ độ</label>
        <input class="form-control" type="number" step="any" name="Latitude" value="@Model?.Latitude" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Kinh độ</label>
        <input class="form-control" type="number" step="any" name="Longitude" value="@Model?.Longitude" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Bán kính (mét)</label>
        <input class="form-control" type="number" name="Radius" value="@Model?.Radius" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Ưu tiên</label>
        <input class="form-control" type="number" name="Priority" value="@(Model?.Priority ?? 0)" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Cooldown (giây)</label>
        <input class="form-control" type="number" name="CooldownSeconds" value="@(Model?.CooldownSeconds ?? 30)" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Ảnh minh họa (URL)</label>
        <input class="form-control" name="ImageUrl" value="@Model?.ImageUrl" />
    </div>
    <div class="col-md-6">
        <label class="form-label">QR Code Payload</label>
        <input class="form-control" name="QrCode" placeholder="e.g. POI:123 hoặc mã tuỳ chỉnh" value="@Model?.QrCode" />
        <small class="form-text text-muted">Nếu nhập, quét mã này sẽ phát thuyết minh POI này.</small>
    </div>
    <div class="col-12">
        <button class="btn btn-primary" type="submit">Tạo POI</button>
        <a class="btn btn-secondary ms-2" href="/PoiAdmin">Quay lại</a>
    </div>
</form>
