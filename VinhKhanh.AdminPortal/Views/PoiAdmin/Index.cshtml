@model List<VinhKhanh.AdminPortal.Models.AdminPoiOverviewDto>

@{
    var total = Model?.Count ?? 0;
    var warningCount = Model?.Count(x => x.Warnings != null && x.Warnings.Any()) ?? 0;

    TimeZoneInfo vnTz;
    try
    {
        vnTz = TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time");
    }
    catch
    {
        vnTz = TimeZoneInfo.Local;
    }

    string ToVnFromUtc(DateTime utc, string format = "HH:mm:ss dd/MM")
    {
        var u = utc.Kind == DateTimeKind.Utc ? utc : DateTime.SpecifyKind(utc, DateTimeKind.Utc);
        var vn = TimeZoneInfo.ConvertTimeFromUtc(u, vnTz);
        return vn.ToString(format);
    }
}

@section Head {
    <style>
        .poi-toolbar-card {
            border: 1px solid #ececec;
            border-radius: 12px;
            padding: 12px;
            background: #fff;
            margin-bottom: 12px;
        }

        .poi-stat {
            border-radius: 10px;
            padding: 8px 12px;
            background: #f8f9fa;
            border: 1px solid #ececec;
            font-size: .92rem;
        }

        .poi-table td {
            vertical-align: top;
        }

        .warning-list {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            max-width: 220px;
        }

        .action-stack {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6px;
            min-width: 160px;
        }

        .action-stack .btn {
            padding: .2rem .45rem;
            font-size: .8rem;
        }
    </style>
}

<h1>Danh sách POI</h1>
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">Không có POI nào trong hệ thống. Hãy kiểm tra lại API backend hoặc thêm mới POI.</div>
}

<div class="d-flex gap-2 flex-wrap mb-3">
    <div class="poi-stat">Tổng POI: <strong>@total</strong></div>
    <div class="poi-stat">Cảnh báo dữ liệu: <strong>@warningCount</strong></div>
</div>

<div class="d-flex gap-2 mb-3">
    <a class="btn btn-primary" href="/PoiAdmin/Create">+ Thêm POI mới</a>
    <form asp-action="RegenerateQrAll" method="post" onsubmit="return confirm('Regen toàn bộ QR theo IP LAN hiện tại của máy chủ? Dùng khi đổi mạng/Wi-Fi để tránh lỗi quét từ điện thoại bên ngoài.');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-primary">Regen QR toàn bộ</button>
    </form>
</div>

<form method="get" class="row g-2 mb-3 poi-toolbar-card">
    <div class="col-md-3 col-lg-2">
        <select class="form-select" name="published">
            <option value="">Tất cả trạng thái</option>
            <option value="true" selected="@(Context.Request.Query["published"] == "true")">Đã duyệt</option>
            <option value="false" selected="@(Context.Request.Query["published"] == "false")">Đang ẩn / Chưa duyệt</option>
        </select>
    </div>
    <div class="col-md-3 col-lg-2">
        <input class="form-control" name="owner" placeholder="Owner email/tên" value="@Context.Request.Query["owner"]" />
    </div>
    <div class="col-md-3 col-lg-2">
        <input class="form-control" name="category" placeholder="Danh mục" value="@Context.Request.Query["category"]" />
    </div>
    <div class="col-md-3 col-lg-2">
        <input class="form-control" name="poiId" type="number" min="1" placeholder="ID POI" value="@Context.Request.Query["poiId"]" />
    </div>
    <div class="col-md-3 col-lg-2">
        <select class="form-select" name="hasContent">
            <option value="">Content: tất cả</option>
            <option value="true" selected="@(Context.Request.Query["hasContent"] == "true")">Có content</option>
            <option value="false" selected="@(Context.Request.Query["hasContent"] == "false")">Thiếu content</option>
        </select>
    </div>
    <div class="col-md-3 col-lg-2">
        <button class="btn btn-outline-secondary w-100" type="submit">Lọc</button>
    </div>
</form>

<form asp-action="BulkAction" method="post" id="bulkForm" onsubmit="return confirmBulk(this)">
    @Html.AntiForgeryToken()
    <input type="hidden" id="bulkActionType" name="actionType" value="" />

    <div class="gap-2 mb-2" id="bulkActionBar" style="display:none;">
        <button type="button" onclick="submitBulk('publish')" class="btn btn-sm btn-success">Duyệt</button>
        <button type="button" onclick="submitBulk('unpublish')" class="btn btn-sm btn-warning">Ẩn</button>
        <button type="button" onclick="submitBulk('delete')" class="btn btn-sm btn-danger">Xóa</button>
    </div>

    <table class="table table-striped table-bordered align-middle poi-table">
        <thead>
            <tr>
                <th><input type="checkbox" id="chkAll" /></th>
                <th>Tên</th>
                <th>Owner</th>
                <th>Loại</th>
                <th>Vĩ độ</th>
                <th>Kinh độ</th>
                <th>Bán kính</th>
                <th>Trạng thái</th>
                <th>Chất lượng dữ liệu</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model ?? new List<VinhKhanh.AdminPortal.Models.AdminPoiOverviewDto>())
            {
                <tr data-poi-id="@p.Id">
                    <td><input type="checkbox" name="selectedPoiIds" value="@p.Id" class="chk-poi" /></td>
                    <td>
                        <strong>@p.Name</strong>
                        <div><small class="text-muted">ID: @p.Id</small></div>
                    </td>
                    <td>
                        <div><strong>@(string.IsNullOrWhiteSpace(p.OwnerName) ? "N/A" : p.OwnerName)</strong></div>
                        <small class="text-muted">@(string.IsNullOrWhiteSpace(p.OwnerEmail) ? "N/A" : p.OwnerEmail)</small>
                    </td>
                    <td>@p.Category</td>
                    <td>@p.Latitude.ToString("0.00000")</td>
                    <td>@p.Longitude.ToString("0.00000")</td>
                    <td>@p.Radius.ToString("0")m</td>
                    <td>
                        @if (p.IsPublished)
                        {
                            <span class="badge bg-light text-dark border">Hiển thị</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Đang ẩn</span>
                        }
                        @if (!p.IsPublished && !string.IsNullOrWhiteSpace(p.PendingRequestType))
                        {
                            <span class="badge bg-warning text-dark">Chờ duyệt @p.PendingRequestType</span>
                        }
                        @if (p.IsSaved)
                        {
                            <span class="badge bg-info">Yêu thích</span>
                        }
                    </td>
                    <td>
                        @if (p.Warnings != null && p.Warnings.Any())
                        {
                            <div class="warning-list">
                                @foreach (var warning in p.Warnings.Take(3))
                                {
                                    <span class="badge bg-danger">@warning</span>
                                }
                                @if (p.Warnings.Count > 3)
                                {
                                    <span class="badge bg-secondary">+@(p.Warnings.Count - 3)</span>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="badge bg-success">OK</span>
                        }
                    </td>
                    <td>
                        <div class="action-stack">
                            <a class="btn btn-sm btn-info" href="/PoiAdmin/Details/@p.Id">Chi tiết</a>
                            <a class="btn btn-sm btn-warning" href="/PoiAdmin/Edit/@p.Id">Sửa</a>
                            <a class="btn btn-sm btn-secondary" href="/AudioAdmin/Index?poiId=@p.Id">Audio</a>
                            <a class="btn btn-sm btn-light" href="/TranslationAdmin/Index?poiId=@p.Id">Bản dịch</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</form>

<script>
    function updateBulkActionVisibility() {
        const anyChecked = Array.from(document.querySelectorAll('.chk-poi')).some(c => c.checked);
        const bulkBar = document.getElementById('bulkActionBar');
        if (bulkBar) {
            bulkBar.style.display = anyChecked ? 'block' : 'none';
        }
    }

    const chkAll = document.getElementById('chkAll');
    if (chkAll) {
        chkAll.addEventListener('change', function () {
            document.querySelectorAll('.chk-poi').forEach(c => c.checked = chkAll.checked);
            updateBulkActionVisibility();
        });
    }

    document.querySelectorAll('.chk-poi').forEach(c => {
        c.addEventListener('change', updateBulkActionVisibility);
    });

    updateBulkActionVisibility();

    function submitBulk(actionType) {
        document.getElementById('bulkActionType').value = actionType;
        document.getElementById('bulkForm').requestSubmit();
    }

    function confirmBulk() {
        const anyChecked = Array.from(document.querySelectorAll('.chk-poi')).some(c => c.checked);
        if (!anyChecked) {
            alert('Bạn chưa chọn POI nào.');
            return false;
        }

        const action = document.getElementById('bulkActionType').value;
        if (action === 'delete') {
            return confirm('Bạn chắc chắn muốn xóa các POI đã chọn? Hành động này không thể hoàn tác.');
        }
        if (action === 'publish') {
            return confirm('Bạn có đồng ý hiển thị các POI đã chọn không?');
        }
        if (action === 'unpublish') {
            return confirm('Bạn có đồng ý ẩn các POI đã chọn không?');
        }

        return true;
    }

</script>
