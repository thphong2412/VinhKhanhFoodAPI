@model List<VinhKhanh.Shared.PoiModel>

<h1>Danh sách POI</h1>
<p><a class="btn btn-primary mb-3" href="/PoiAdmin/Create">+ Thêm POI mới</a></p>
<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>Tên</th>
            <th>Loại</th>
            <th>Vĩ độ</th>
            <th>Kinh độ</th>
            <th>Bán kính</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var p in Model ?? new List<VinhKhanh.Shared.PoiModel>())
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Category</td>
                <td>@p.Latitude</td>
                <td>@p.Longitude</td>
                <td>@p.Radius</td>
                <td>
                    @if (p.IsSaved)
                    {
                        <span class="badge bg-success">Đã lưu</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Chưa lưu</span>
                    }
                </td>
                <td>
                    <a class="btn btn-sm btn-info" href="/PoiAdmin/Details/@p.Id">Chi tiết</a>
                    <a class="btn btn-sm btn-warning" href="/PoiAdmin/Edit/@p.Id">Sửa</a>
                </td>
            </tr>
        }
    </tbody>
</table>