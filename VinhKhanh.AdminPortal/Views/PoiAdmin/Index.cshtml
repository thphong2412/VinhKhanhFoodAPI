@model List<VinhKhanh.Shared.PoiModel>

<h1>Danh sách POI</h1>
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">Không có POI nào trong hệ thống. Hãy kiểm tra lại API backend hoặc thêm mới POI.</div>
}
<p><a class="btn btn-primary mb-3" href="/PoiAdmin/Create">+ Thêm POI mới</a></p>
<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>Tên</th>
            <th>Loại</th>
            <th>Vĩ độ</th>
            <th>Kinh độ</th>
            <th>Bán kính</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var p in Model ?? new List<VinhKhanh.Shared.PoiModel>())
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Category</td>
                <td>@p.Latitude</td>
                <td>@p.Longitude</td>
                <td>@p.Radius</td>
                <td>
                    @if (p.IsPublished)
                    {
                        <span class="badge bg-success">Đã xuất bản</span>
                    }
                    else
                    {
                        <span class="badge bg-warning">Chưa xuất bản</span>
                    }
                    @if (p.IsSaved)
                    {
                        <span class="badge bg-info">Yêu thích</span>
                    }
                </td>
                <td>
                    <a class="btn btn-sm btn-info" href="/PoiAdmin/Details/@p.Id">Chi tiết</a>
                    <a class="btn btn-sm btn-warning" href="/PoiAdmin/Edit/@p.Id">Sửa</a>
                    <a class="btn btn-sm btn-secondary" href="/AudioAdmin/Index?poiId=@p.Id">Audio</a>
                    <a class="btn btn-sm btn-light" href="/TranslationAdmin/Index?poiId=@p.Id">Bản dịch</a>
                    @if (!p.IsPublished)
                    {
                        <form asp-action="ApprovePoi" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button class="btn btn-sm btn-success">Duyệt & Phát</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>