@model VinhKhanh.Shared.PoiModel
@{
    var vi = ViewBag.ViContent as VinhKhanh.Shared.ContentModel ?? new VinhKhanh.Shared.ContentModel();
    var apiBaseUrl = (ViewBag.ApiBaseUrl as string ?? string.Empty).Trim();

    string ResolveImageUrl(string raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        if (Uri.TryCreate(raw, UriKind.Absolute, out _)) return raw;
        if (string.IsNullOrWhiteSpace(apiBaseUrl)) return raw;
        return $"{apiBaseUrl.TrimEnd('/')}/{raw.TrimStart('/')}";
    }
}

<h1>Sửa POI</h1>
<form asp-action="Edit" method="post" enctype="multipart/form-data" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />
    <input type="hidden" name="OwnerId" value="@Model.OwnerId" />

    <h3>Thông tin cơ bản</h3>
    <div class="col-md-6">
        <label class="form-label">Tên POI</label>
        <input class="form-control" name="Name" value="@Model.Name" required />
    </div>
    <div class="col-md-6">
        <label class="form-label">Loại (Category)</label>
        <select class="form-select" name="Category" required>
            <option value="">-- Chọn danh mục --</option>
            <option value="Food" selected="@(Model?.Category == "Food")">Ăn uống (Food)</option>
            <option value="Restaurant" selected="@(Model?.Category == "Restaurant")">Nhà hàng (Restaurant)</option>
            <option value="Attraction" selected="@(Model?.Category == "Attraction")">Điểm du lịch (Attraction)</option>
            <option value="Shopping" selected="@(Model?.Category == "Shopping")">Mua sắm (Shopping)</option>
            <option value="Hotel" selected="@(Model?.Category == "Hotel")">Khách sạn (Hotel)</option>
            <option value="Other" selected="@(Model?.Category == "Other")">Khác (Other)</option>
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Vĩ độ (Latitude)</label>
        <input class="form-control" type="number" step="any" name="Latitude" value="@Model.Latitude" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Kinh độ (Longitude)</label>
        <input class="form-control" type="number" step="any" name="Longitude" value="@Model.Longitude" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Bán kính (mét)</label>
        <input class="form-control" type="number" name="Radius" value="@Model.Radius" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Ưu tiên (Priority)</label>
        <input class="form-control" type="number" name="Priority" value="@Model.Priority" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Cooldown (giây)</label>
        <input class="form-control" type="number" name="CooldownSeconds" value="@Model.CooldownSeconds" />
    </div>
    <div class="col-md-12">
        <label class="form-label">📸 Ảnh POI (chọn nhiều tệp)</label>
        <input class="form-control" type="file" name="ImageFiles" multiple accept="image/*" />
        <small class="text-muted">Nếu chọn ảnh mới, hệ thống sẽ cập nhật danh sách ảnh cho POI.</small>
    </div>

    @{
        var existingImages = (Model.ImageUrl ?? string.Empty)
            .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }
    @if (existingImages.Any())
    {
        <div class="col-md-12">
            <label class="form-label">Ảnh hiện có</label>
            <div class="row g-2">
                @foreach (var img in existingImages)
                {
                    <div class="col-md-3 col-6">
                        <div class="border rounded p-2 h-100">
                            <img src="@ResolveImageUrl(img)" class="img-fluid rounded mb-2" style="height:120px; width:100%; object-fit:cover;" />
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="DeleteImageUrls" value="@img" id="del_@img.GetHashCode()" />
                                <label class="form-check-label" for="del_@img.GetHashCode()">Xóa ảnh này</label>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <small class="text-muted">Không tích gì thì vẫn giữ ảnh cũ. Upload thêm sẽ cộng vào danh sách hiện có.</small>
        </div>
    }

    <h3 class="mt-4">Chi tiết</h3>
    <div class="col-md-6">
        <label class="form-label">Tiêu đề (Title)</label>
        <input class="form-control" name="ContentTitle_VI" value="@vi.Title" placeholder="Tên chi tiết" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Phụ đề (Subtitle)</label>
        <input class="form-control" name="ContentSubtitle_VI" value="@vi.Subtitle" placeholder="Mô tả ngắn" />
    </div>
    <div class="col-12">
        <label class="form-label">Mô tả (Description)</label>
        <textarea class="form-control" name="ContentDescription_VI" rows="3" placeholder="Mô tả chi tiết">@vi.Description</textarea>
    </div>
    <div class="col-md-3">
        <label class="form-label">Giá tối thiểu</label>
        <input class="form-control" name="ContentPriceMin_VI" value="@vi.PriceMin" placeholder="Ví dụ: 45.000 VND" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Giá tối đa</label>
        <input class="form-control" name="ContentPriceMax_VI" value="@vi.PriceMax" placeholder="Ví dụ: 100.000 VND" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Đánh giá (Rating)</label>
        <input class="form-control" type="number" step="0.1" name="ContentRating_VI" min="0" max="5" value="@vi.Rating" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Giờ mở cửa</label>
        <input class="form-control" name="ContentOpenTime_VI" value="@vi.OpenTime" placeholder="10:00" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Giờ đóng cửa</label>
        <input class="form-control" name="ContentCloseTime_VI" value="@vi.CloseTime" placeholder="22:00" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Số điện thoại (PhoneNumber)</label>
        <input class="form-control" name="ContentPhoneNumber_VI" value="@vi.PhoneNumber" placeholder="0123456789" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Địa chỉ (Address)</label>
        <input class="form-control" name="ContentAddress_VI" value="@vi.Address" placeholder="Số 123, Đường ABC" />
    </div>

    <h3 class="mt-4">Trạng thái</h3>
    <div class="col-md-12">
        <label class="form-label">Công khai</label>
        <select class="form-control" name="IsPublished">
            <option value="true" selected="@(Model.IsPublished ? "selected" : null)">Đã duyệt (Công khai)</option>
            <option value="false" selected="@(!Model.IsPublished ? "selected" : null)">Chưa duyệt (Ẩn)</option>
        </select>
    </div>

    <div class="col-12">
        <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
        <a class="btn btn-secondary ms-2" href="/PoiAdmin">Quay lại</a>
    </div>
</form>

<hr />
<h3>Xóa POI</h3>
<form asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa POI này?');">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <button class="btn btn-danger" type="submit">Xóa POI này</button>
</form>
