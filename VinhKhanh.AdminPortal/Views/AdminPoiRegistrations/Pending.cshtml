@model List<VinhKhanh.AdminPortal.Models.PoiRegistrationDto>
@{
    ViewData["Title"] = "Chờ duyệt POI";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="text-warning"><i class="bi bi-hourglass-split"></i> POI chờ duyệt</h2>
            <p class="text-muted">Danh sách các POI mới được owner tạo, chưa được duyệt</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            @if (Model?.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>POI Name</th>
                                <th>Owner ID</th>
                                <th>Danh mục</th>
                                <th>Loại yêu cầu</th>
                                <th>Owner đã sửa</th>
                                <th>Ngày tạo</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var poi in Model)
                        {
                            <tr>
                                <td><span class="badge bg-primary">@poi.Id</span></td>
                                <td><strong>@poi.Name</strong></td>
                                <td>@poi.OwnerId</td>
                                <td>
                                    <span class="badge bg-info">@poi.Category</span>
                                </td>
                                <td>
                                    @{
                                        var reqType = (poi.RequestType ?? "create").Trim().ToLowerInvariant();
                                        var reqLabel = reqType switch
                                        {
                                            "update" => "Cập nhật",
                                            "delete" => "Xóa",
                                            _ => "Tạo mới"
                                        };
                                        var reqClass = reqType switch
                                        {
                                            "update" => "bg-primary",
                                            "delete" => "bg-danger",
                                            _ => "bg-success"
                                        };
                                    }
                                    <span class="badge @reqClass">@reqLabel</span>
                                </td>
                                <td style="min-width: 260px;">
                                    @if (poi.ChangeSummary?.Count > 0)
                                    {
                                        <ul class="mb-0 ps-3 small">
                                            @foreach (var item in poi.ChangeSummary)
                                            {
                                                <li>@item</li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Không có dữ liệu</span>
                                    }
                                </td>
                                <td>
                                    <small class="text-muted">@poi.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                </td>
                                <td>
                                    <span class="badge bg-warning">
                                        <i class="bi bi-hourglass-split"></i> Chờ duyệt
                                    </span>
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = poi.Id })" class="btn btn-sm btn-info" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle"></i> Tuyệt vời! Không có POI nào chờ duyệt. Tất cả POI đã được xử lý.
                </div>
            }
        </div>
    </div>
</div>
