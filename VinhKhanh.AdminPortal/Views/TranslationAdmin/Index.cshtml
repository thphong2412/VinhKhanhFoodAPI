@model List<VinhKhanh.Shared.ContentModel>
@{
    var poiId = ViewData["PoiId"] ?? 0;
    var vi = Model.FirstOrDefault(x => string.Equals(x.LanguageCode, "vi", StringComparison.OrdinalIgnoreCase));
}

<h1>Quản lý Nội dung & Bản dịch cho POI #@poiId</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5>➕ Thêm bản dịch mới (gốc từ tiếng Việt)</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" id="translationCreateForm">
            <input type="hidden" name="poiId" value="@poiId" />
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Ngôn ngữ</label>
                    <select class="form-control" id="createLanguageCode" name="LanguageCode" required>
                        <option value="">-- Chọn --</option>
                        <option value="vi">Tiếng Việt (vi)</option>
                        <option value="en">English (en)</option>
                        <option value="ru">Русский (ru)</option>
                        <option value="th">ไทย (th)</option>
                        <option value="zh">中文 (zh)</option>
                        <option value="es">Español (es)</option>
                        <option value="fr">Français (fr)</option>
                        <option value="ja">日本語 (ja)</option>
                        <option value="ko">한국어 (ko)</option>
                    </select>
                    <small class="text-muted">Khi đổi ngôn ngữ sẽ tự dịch từ bản tiếng Việt.</small>
                </div>
                <div class="col-md-9 d-flex align-items-end justify-content-end">
                    <button type="button" class="btn btn-outline-light border-primary text-primary" id="btnAutoTranslate">Dịch và lưu ngay</button>
                </div>
            </div>

            <div id="translateStatus" class="mt-2"></div>

            <hr />
            <h5>Chi tiết</h5>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Tiêu đề (Title)</label>
                    <input class="form-control" id="fTitle" name="Title" placeholder="Tên POI" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Phụ đề (Subtitle)</label>
                    <input class="form-control" id="fSubtitle" name="Subtitle" placeholder="Mô tả ngắn" />
                </div>
                <div class="col-12">
                    <label class="form-label">Mô tả (Description)</label>
                    <textarea class="form-control" id="fDescription" name="Description" rows="3" placeholder="Mô tả đầy đủ về POI" required></textarea>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Giá tối thiểu</label>
                    <input class="form-control" id="fPriceMin" name="PriceMin" placeholder="VD: 45.000 VND" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Giá tối đa</label>
                    <input class="form-control" id="fPriceMax" name="PriceMax" placeholder="VD: 100.000 VND" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Đánh giá</label>
                    <input class="form-control" id="fRating" type="number" step="0.1" name="Rating" min="0" max="5" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Giờ mở cửa</label>
                    <input class="form-control" id="fOpenTime" name="OpenTime" placeholder="10:00" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Giờ đóng cửa</label>
                    <input class="form-control" id="fCloseTime" name="CloseTime" placeholder="22:00" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Số điện thoại</label>
                    <input class="form-control" id="fPhoneNumber" name="PhoneNumber" placeholder="0123456789" />
                </div>
                <div class="col-md-12">
                    <label class="form-label">Địa chỉ (Address)</label>
                    <input class="form-control" id="fAddress" name="Address" placeholder="Số 123, Đường ABC" />
                </div>
            </div>

            <div class="mt-3 d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-primary" id="btnAutoFill">Tự động điền</button>
                <button class="btn btn-primary px-4">Thêm thủ công</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header bg-info text-white">
        <h5>📝 Danh sách bản dịch</h5>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-warning">Chưa có bản dịch nào</div>
        }
        else
        {
            @foreach(var group in Model.GroupBy(c => c.LanguageCode))
            {
                var c = group.First();
                <div class="card mb-3">
                    <div class="card-header">
                        @switch(c.LanguageCode)
                        {
                            case "vi": <span class="badge bg-success">🇻🇳 Tiếng Việt</span>; break;
                            case "en": <span class="badge bg-primary">🇺🇸 English</span>; break;
                            case "ja": <span class="badge bg-warning">🇯🇵 日本語</span>; break;
                            case "ko": <span class="badge bg-danger">🇰🇷 한국어</span>; break;
                            case "ru": <span class="badge bg-secondary">🇷🇺 Русский</span>; break;
                            case "th": <span class="badge bg-secondary">🇹🇭 ไทย</span>; break;
                            case "zh": <span class="badge bg-secondary">🇨🇳 中文</span>; break;
                            case "es": <span class="badge bg-secondary">🇪🇸 Español</span>; break;
                            case "fr": <span class="badge bg-secondary">🇫🇷 Français</span>; break;
                        }
                    </div>
                    <div class="card-body">
                        <p><strong>Tiêu đề:</strong> @c.Title</p>
                        <p><strong>Phụ đề:</strong> @c.Subtitle</p>
                        <p><strong>Mô tả:</strong> @c.Description</p>
                        <div class="row">
                            <div class="col-md-3"><strong>Giá:</strong> @c.GetNormalizedPriceRangeDisplay()</div>
                            <div class="col-md-3"><strong>Đánh giá:</strong> ⭐ @c.Rating</div>
                            <div class="col-md-3"><strong>Giờ:</strong> @c.OpeningHours</div>
                            <div class="col-md-3"><strong>SĐT:</strong> @c.PhoneNumber</div>
                        </div>

<script>
    const viSource = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        title = vi?.Title,
        subtitle = vi?.Subtitle,
        description = vi?.Description,
        priceMin = vi?.PriceMin,
        priceMax = vi?.PriceMax,
        rating = vi?.Rating,
        openTime = vi?.OpenTime,
        closeTime = vi?.CloseTime,
        phoneNumber = vi?.PhoneNumber,
        address = vi?.Address
    }));

    function fillForm(data) {
        document.getElementById('fTitle').value = data?.title ?? '';
        document.getElementById('fSubtitle').value = data?.subtitle ?? '';
        document.getElementById('fDescription').value = data?.description ?? '';
        document.getElementById('fPriceMin').value = data?.priceMin ?? '';
        document.getElementById('fPriceMax').value = data?.priceMax ?? '';
        document.getElementById('fRating').value = (data?.rating ?? '') === null ? '' : (data?.rating ?? '');
        document.getElementById('fOpenTime').value = data?.openTime ?? '';
        document.getElementById('fCloseTime').value = data?.closeTime ?? '';
        document.getElementById('fPhoneNumber').value = data?.phoneNumber ?? '';
        document.getElementById('fAddress').value = data?.address ?? '';
    }

    async function autoTranslateNow() {
        const lang = document.getElementById('createLanguageCode').value;
        if (!lang) return;

        if (lang === 'vi') {
            fillForm(viSource || {});
            return;
        }

        try {
            const btn = document.getElementById('btnAutoFill');
            const statusEl = document.getElementById('translateStatus');
            if (btn) {
                btn.setAttribute('disabled', 'disabled');
                btn.textContent = 'Đang dịch...';
            }
            if (statusEl) statusEl.innerHTML = '';

            const res = await fetch(`/TranslationAdmin/AutoTranslate?poiId=@poiId&languageCode=${encodeURIComponent(lang)}`, {
                cache: 'no-store'
            });
            if (!res.ok) {
                alert('Không thể tự động dịch lúc này.');
                if (btn) {
                    btn.removeAttribute('disabled');
                    btn.textContent = 'Tự động điền';
                }
                return;
            }

            const data = await res.json();
            fillForm(data || {});
            if (btn) {
                btn.removeAttribute('disabled');
                btn.textContent = 'Tự động điền';
            }
            if (statusEl) statusEl.innerHTML = '<div class="alert alert-success py-2 mb-0">Đã tự động điền nội dung từ tiếng Việt.</div>';
        } catch {
            alert('Lỗi khi gọi tự động dịch.');
            const btn = document.getElementById('btnAutoFill');
            if (btn) {
                btn.removeAttribute('disabled');
                btn.textContent = 'Tự động điền';
            }
        }
    }

    async function autoTranslateAndSaveNow() {
        const lang = document.getElementById('createLanguageCode').value;
        if (!lang) return;

        const btn = document.getElementById('btnAutoTranslate');
        const statusEl = document.getElementById('translateStatus');

        try {
            if (btn) {
                btn.setAttribute('disabled', 'disabled');
                btn.textContent = 'Đang dịch và lưu...';
            }
            if (statusEl) statusEl.innerHTML = '';

            const body = new URLSearchParams();
            body.append('poiId', '@poiId');
            body.append('languageCode', lang);

            const res = await fetch('/TranslationAdmin/AutoTranslateAndUpsert', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                body: body.toString()
            });

            const data = await res.json();
            if (!res.ok || !data?.ok) {
                if (statusEl) statusEl.innerHTML = '<div class="alert alert-danger py-2 mb-0">Dịch tự động thất bại. Vui lòng thử lại.</div>';
                return;
            }

            if (statusEl) statusEl.innerHTML = `<div class="alert alert-success py-2 mb-0">${data.message || 'Đã dịch và lưu thành công.'}</div>`;
            setTimeout(() => window.location.reload(), 600);
        } catch {
            if (statusEl) statusEl.innerHTML = '<div class="alert alert-danger py-2 mb-0">Lỗi khi gọi dịch tự động.</div>';
        } finally {
            if (btn) {
                btn.removeAttribute('disabled');
                btn.textContent = 'Dịch và lưu ngay';
            }
        }
    }

    document.getElementById('createLanguageCode')?.addEventListener('change', autoTranslateNow);
    document.getElementById('btnAutoFill')?.addEventListener('click', autoTranslateNow);
    document.getElementById('btnAutoTranslate')?.addEventListener('click', autoTranslateAndSaveNow);
</script>
                        <p><strong>Địa chỉ:</strong> @c.Address</p>
                        <form asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Xóa bản dịch này?');">
                            <input type="hidden" name="id" value="@c.Id" />
                            <input type="hidden" name="poiId" value="@poiId" />
                            <button class="btn btn-sm btn-danger">🗑️ Xóa</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="mt-3">
    <a href="/PoiAdmin" class="btn btn-secondary">← Quay lại danh sách POI</a>
</div>
