@model List<VinhKhanh.Shared.ContentModel>
@{
    var poiId = ViewData["PoiId"] ?? 0;
}

<h1>Quản lý Nội dung & Bản dịch cho POI #@poiId</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5>➕ Thêm bản dịch mới</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <input type="hidden" name="poiId" value="@poiId" />
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">Ngôn ngữ</label>
                    <select class="form-control" name="LanguageCode" required>
                        <option value="">-- Chọn --</option>
                        <option value="vi">Tiếng Việt (vi)</option>
                        <option value="en">English (en)</option>
                        <option value="ja">日本語 (ja)</option>
                        <option value="ko">한국어 (ko)</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tiêu đề</label>
                    <input class="form-control" name="Title" placeholder="Tên POI" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Phụ đề</label>
                    <input class="form-control" name="Subtitle" placeholder="Mô tả ngắn" required />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100">Thêm</button>
                </div>
            </div>
            <div class="mt-3">
                <label class="form-label">Mô tả chi tiết</label>
                <textarea class="form-control" name="Description" rows="3" placeholder="Mô tả đầy đủ về POI" required></textarea>
            </div>
            <div class="row g-3 mt-2">
                <div class="col-md-4">
                    <label class="form-label">Khoảng giá</label>
                    <input class="form-control" name="PriceRange" placeholder="50k-200k" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Đánh giá</label>
                    <input class="form-control" type="number" step="0.1" name="Rating" min="0" max="5" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Giờ mở cửa</label>
                    <input class="form-control" name="OpeningHours" placeholder="10:00 - 22:00" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Số điện thoại</label>
                    <input class="form-control" name="PhoneNumber" placeholder="0123456789" />
                </div>
                <div class="col-md-8">
                    <label class="form-label">Địa chỉ</label>
                    <input class="form-control" name="Address" placeholder="Số 123, Đường ABC" />
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header bg-info text-white">
        <h5>📝 Danh sách bản dịch</h5>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-warning">Chưa có bản dịch nào</div>
        }
        else
        {
            @foreach(var group in Model.GroupBy(c => c.LanguageCode))
            {
                var c = group.First();
                <div class="card mb-3">
                    <div class="card-header">
                        @switch(c.LanguageCode)
                        {
                            case "vi": <span class="badge bg-success">🇻🇳 Tiếng Việt</span>; break;
                            case "en": <span class="badge bg-primary">🇺🇸 English</span>; break;
                            case "ja": <span class="badge bg-warning">🇯🇵 日本語</span>; break;
                            case "ko": <span class="badge bg-danger">🇰🇷 한국어</span>; break;
                        }
                    </div>
                    <div class="card-body">
                        <p><strong>Tiêu đề:</strong> @c.Title</p>
                        <p><strong>Phụ đề:</strong> @c.Subtitle</p>
                        <p><strong>Mô tả:</strong> @c.Description</p>
                        <div class="row">
                            <div class="col-md-3"><strong>Giá:</strong> @c.PriceRange</div>
                            <div class="col-md-3"><strong>Đánh giá:</strong> ⭐ @c.Rating</div>
                            <div class="col-md-3"><strong>Giờ:</strong> @c.OpeningHours</div>
                            <div class="col-md-3"><strong>SĐT:</strong> @c.PhoneNumber</div>
                        </div>
                        <p><strong>Địa chỉ:</strong> @c.Address</p>
                        <form asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Xóa bản dịch này?');">
                            <input type="hidden" name="id" value="@c.Id" />
                            <input type="hidden" name="poiId" value="@poiId" />
                            <button class="btn btn-sm btn-danger">🗑️ Xóa</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="mt-3">
    <a href="/PoiAdmin" class="btn btn-secondary">← Quay lại danh sách POI</a>
</div>
