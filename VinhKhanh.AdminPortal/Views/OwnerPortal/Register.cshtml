@{
    Layout = "_Layout";
}

<h2>Đăng ký chủ quán</h2>

<form method="post" asp-controller="OwnerPortal" asp-action="Register">
    <div class="mb-3">
        <label class="form-label">Email</label>
        <input name="email" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Mật khẩu</label>
        <input name="password" type="password" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Tên quán</label>
        <input name="shopName" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Địa chỉ</label>
        <input name="shopAddress" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">CCCD</label>
        <input name="cccd" class="form-control" />
    </div>
    <button class="btn btn-primary" type="submit">Đăng ký</button>
</form>
